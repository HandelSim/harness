# harness — environment variables.
#
# This file documents every variable the project reads. Copy it to .env
# at the top of the clone — the install root IS the clone. docker compose
# is invoked with `--env-file <install-root>/.env`.
#
# Required values are marked REQUIRED; you must fill these in before
# running 'harness start'. Everything else has a sensible default.
#
# Per-MCP variables are tagged with one of:
#   REQUIRED for <mcp>: ...
#   OPTIONAL for <mcp> (default: ...): ...
#   OPTIONAL, used by multiple MCPs: ...

# ---------------------------------------------------------------------------
# Upstream API (consumed by the proxy)
# ---------------------------------------------------------------------------

# REQUIRED. Base URL of the third-party API the proxy will call.
PROXY_API_URL=

# REQUIRED. API key / bearer token for the upstream API. Sensitive — never commit.
PROXY_API_KEY=

# REQUIRED. Model identifier to pass through to the upstream API.
PROXY_API_MODEL=

# Upstream request timeout in seconds. Defaults to 180.
PROXY_TIMEOUT=180

# Cooperative-prompt injection mode. Controls how the proxy tells the upstream
# model about available tools (since the upstream may not natively support
# tool-use). Five values:
#
#   user_front  (default, recommended) — user's request appears FIRST, then
#               tool definitions. Same active-instruction structure as `user`
#               mode but with the request in primacy position rather than
#               buried after 10-15K tokens of tool schemas. Best balance of
#               tool reliability + conversation-context retention.
#
#   user_bookend — user's request appears FIRST, then tools, then request
#               AGAIN. Maximizes attention on the actual question via both
#               primacy and recency. Slightly higher token cost (request
#               text duplicated) but most reliable instruction-following.
#
#   user        — legacy behavior: tools first, then request at the end.
#               Reliable for tool use but causes the model to lose
#               conversation context because the user's actual question
#               gets buried under tool schemas.
#
#   system      — tool definitions in the system message only. User turns
#               pass through unchanged. Cheapest (no per-turn injection)
#               but some upstreams treat system content as background and
#               don't reliably emit tool calls.
#
#   hybrid      — tools in the system message + a brief reminder on each
#               user turn. Same caveats as `system` for tool reliability.
#
PROXY_PROMPT_MODE=user_front

# Whether to convert the `system` role to `user` in the upstream request.
# Some upstreams (notably some Gemini-compatible OpenAI-compat endpoints)
# silently drop the system role. The model never sees claude-code's system
# prompt — tool descriptions, environment context, CLAUDE.md content. The
# failure is invisible (no error; the model just doesn't follow
# system-level instructions).
#
# When 1 (default), the proxy converts any system message(s) at the head
# of the conversation into a user message, then inserts a stub assistant
# turn between the converted-system content and the actual first user
# message. This satisfies upstreams that require strict role-alternation
# (no two consecutive user messages).
#
# When 0, system messages pass through unchanged. Use 0 if you've
# verified your upstream supports the system role end-to-end (test by
# sending a system instruction and confirming the model follows it).
PROXY_CHANGE_SYSTEM_PROMPT_TO_USER=1

# ---------------------------------------------------------------------------
# Proxy service (containers on the harness-net bridge)
# ---------------------------------------------------------------------------

# Bind address inside the proxy container. 0.0.0.0 because the proxy is only
# reachable on the docker network — the host does not publish this port.
PROXY_HOST=0.0.0.0

# Port the proxy listens on inside the container. Ollama's RemoteHost URL
# (http://proxy:${PROXY_PORT}) is constructed from this.
PROXY_PORT=8000

# OPTIONAL — proxy debug dumps. Leave empty (default) to disable.
# When set, the proxy writes JSON files to this directory for every
# request: the raw ollama request, the translated upstream request, and
# the upstream response. Useful for debugging tool-call issues. Can
# produce many files quickly. Path is INSIDE the proxy container; the
# default compose bind-mounts <install-root>/state/output to it.
#
# Default: empty (no debug dumps written)
# Linux/macOS example: OUTPUT_DIR=/output
#
# WINDOWS NOTE: Git Bash auto-translates leading `/` paths when passing
# env vars to Docker, so OUTPUT_DIR=/output ends up as
# `C:/Program Files/Git/output` inside the container. Use a double-slash
# to bypass MSYS path translation: OUTPUT_DIR=//output. Both forms
# bind-mount to the same host directory at <install-root>/state/output/.
OUTPUT_DIR=

# ---------------------------------------------------------------------------
# Ollama service
# ---------------------------------------------------------------------------

# Pinned ollama base image tag. The harness was verified against this version.
# RemoteHost stub-model support landed in v0.12.0; do not pin below that.
OLLAMA_VERSION=0.21.2

# Name of the stub model registered against ollama. Agents target this name.
OLLAMA_AGENT_MODEL=harness

# Context length advertised by the stub model.
OLLAMA_CONTEXT_LENGTH=200000

# Optional: host port to publish ollama on. Leave blank to keep ollama
# internal-only (the default — agents reach it on the docker network).
#
# When set, the harness script generates a runtime override that publishes
# ollama on this host port. Useful for poking at ollama from outside docker.
PUBLISH_OLLAMA_PORT=

# ---------------------------------------------------------------------------
# MCP servers (consumed by registry compose snippets)
# ---------------------------------------------------------------------------

# OPTIONAL for Serena (default: the host's $HOME of whoever invoked harness).
# Path on the host that registry MCP services may mount read-only for code
# analysis. Currently consumed by Serena's compose snippet. Leaving blank
# means the harness wrapper falls back to your $HOME, which matches
# "see whatever is in my home". Narrow it if you only want to expose
# specific projects:
#   HARNESS_PROJECTS_ROOT=/home/you/code
# Mounts are read-only; agents still own the write path via their normal
# /workspace bind-mount.
HARNESS_PROJECTS_ROOT=

# OPTIONAL for Serena (default: dashboard internal-only).
# Set to e.g. 24282 to publish Serena's web dashboard on that host port so
# you can browse it from outside docker. Leave blank to keep the dashboard
# reachable only from inside the harness-net bridge. Only consulted when
# the Serena MCP is enabled.
SERENA_DASHBOARD_PORT=

# ---------------------------------------------------------------------------
# Network / firewall overrides
# ---------------------------------------------------------------------------

# Path to the per-service firewall override JSON. Defaults to
# <install-root>/.harness-net-overrides.json. Managed by `harness net open`
# and `harness net close`; only set this if you want the overrides file in a
# non-default location (e.g. tests).
HARNESS_NET_OVERRIDES_PATH=
