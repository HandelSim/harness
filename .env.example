# harness — environment variables.
#
# This file documents every variable the project reads. Copy it to ../.env
# (one directory above the clone — the "install root") and fill in values.
# docker compose is invoked with `--env-file <install-root>/.env`.
#
# Required values are marked REQUIRED; you must fill these in before
# running 'harness start'. Everything else has a sensible default.

# ---------------------------------------------------------------------------
# Upstream API (consumed by the proxy)
# ---------------------------------------------------------------------------

# REQUIRED. Base URL of the third-party API the proxy will call.
PROXY_API_URL=

# REQUIRED. API key / bearer token for the upstream API. Sensitive — never commit.
PROXY_API_KEY=

# REQUIRED. Model identifier to pass through to the upstream API.
PROXY_API_MODEL=

# Upstream request timeout in seconds. Defaults to 180.
PROXY_TIMEOUT=180

# ---------------------------------------------------------------------------
# Proxy service (containers on the harness-net bridge)
# ---------------------------------------------------------------------------

# Bind address inside the proxy container. 0.0.0.0 because the proxy is only
# reachable on the docker network — the host does not publish this port.
PROXY_HOST=0.0.0.0

# Port the proxy listens on inside the container. Ollama's RemoteHost URL
# (http://proxy:${PROXY_PORT}) is constructed from this.
PROXY_PORT=8000

# Where the proxy writes per-request debug files (mounted into the container).
# Set to empty to disable debug-file writes.
OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# Ollama service
# ---------------------------------------------------------------------------

# Pinned ollama base image tag. The harness was verified against this version.
# RemoteHost stub-model support landed in v0.12.0; do not pin below that.
OLLAMA_VERSION=0.21.2

# Name of the stub model registered against ollama. Agents target this name.
OLLAMA_AGENT_MODEL=harness

# Context length advertised by the stub model.
OLLAMA_CONTEXT_LENGTH=200000

# Optional: host port to publish ollama on. Leave blank to keep ollama
# internal-only (the default — agents reach it on the docker network).
#
# When set, the harness script generates a runtime override that publishes
# ollama on this host port. Useful for poking at ollama from outside docker.
PUBLISH_OLLAMA_PORT=
