# Defensive — the real .env lives at the install root (one dir above the clone).
# This prevents accidental commits if anyone creates one inside the clone.
.env

# Python
__pycache__/
*.pyc

# Editor / OS
.DS_Store
*.swp
*.swo

# Runtime artifacts that belong at the install root, never inside the clone
output/
agent/
ollama-data/

# Distribution zip output (Phase 4)
dist/

# Runtime override generated by the harness script
.harness-runtime.yml
