# User config — seeded by install.sh from .env.example /
# .harness-allowlist.example, then user-owned. Sensitive (PROXY_API_KEY etc.).
.env
.harness-allowlist
.harness-net-overrides.json

# Runtime state — bind-mounted into containers; not part of the repo.
# Includes output/, agent/{claude,opencode}/, ollama-data/, mcp/<name>/,
# and the .harness-runtime.yml compose override.
state/

# harness is distributed via direct git clone — no zip build artifact.

# Python / editor / OS
__pycache__/
*.pyc
.DS_Store
*.swp
*.swo
# Windows / Git Bash crash dumps
*.stackdump

# Local Claude Code state (lock files for skill scheduling, etc.)
.claude/
