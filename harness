# status: per-MCP diagnostic. No exit code on warnings; the user is asking
# for info, not running a check.
cmd_mcp_status() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "usage: harness mcp status <name>"
        exit 1
    fi
    if ! mcp_is_installed "$name"; then
        printf 'name:      %s\n' "$name"
        printf 'state:     available\n'
        if [[ -d "$registry_dir/$name" ]]; then
            printf 'registry:  %s\n' "$registry_dir/$name"
        else
            printf 'registry:  (not in registry)\n'
        fi
        return
    fi
    local enabled state runtime
    if mcp_is_enabled "$name"; then
        enabled="true"
        state="installed-enabled"
    else
        enabled="false"
        state="installed-disabled"
    fi
    runtime=$(mcp_runtime_status "$name")
    printf 'name:      %s\n' "$name"
    printf 'state:     %s\n' "$state"
    printf 'enabled:   %s\n' "$enabled"
    printf 'runtime:   %s\n' "$runtime"
    printf 'install:   %s\n' "$mcp_active_dir/$name"
    printf 'data:      %s\n' "$mcp_active_dir/$name/data"
    if [[ -f "$registry_dir/$name/compose.yml" ]]; then
        printf 'origin:    registry (%s)\n' "$registry_dir/$name"
    else
        printf 'origin:    custom\n'
    fi
    # Surface the declared services so the user knows what 'mcp logs' will
    # tail and what 'mcp up/down' acts on.
    local svcs
    svcs=$(mcp_services_of "$name" | paste -sd, -)
    printf 'services:  %s\n' "${svcs:-(none)}"
}

cmd_mcp_install_custom() {
    local src="${1:-}"
    if [[ -z "$src" ]]; then
        err "usage: harness mcp install-custom <path>"
        exit 1
    fi
    if [[ ! -d "$src" ]]; then
        err "$src is not a directory"
        exit 1
    fi
    if [[ ! -f "$src/compose.yml" ]]; then
        err "$src is missing compose.yml"
        exit 1
    fi
    local name
    name=$(basename "$(realpath "$src")")
    local dest="$mcp_active_dir/$name"
    if [[ -d "$dest" ]]; then
        err "$name is already installed (remove $dest first or use a different basename)"
        exit 1
    fi
    mkdir -p "$mcp_active_dir"
    cp -a "$src" "$dest"
    mkdir -p "$dest/data"
    mcp_set_enabled "$name" "true"
    echo "installed custom MCP: $name (from $src)"
    echo "state: installed-enabled"
    echo "next: run 'harness start' to bring it up"
}

cmd_mcp() {
    local sub="${1:-help}"
    if [[ $# -gt 0 ]]; then shift; fi
    case "$sub" in
        help|-h|--help) cmd_mcp_help ;;
        list)           cmd_mcp_list ;;
        install)        cmd_mcp_install "$@" ;;
        uninstall)      cmd_mcp_uninstall "$@" ;;
        enable)         cmd_mcp_enable "$@" ;;
        disable)        cmd_mcp_disable "$@" ;;
        up)             cmd_mcp_up "$@" ;;
        down)           cmd_mcp_down "$@" ;;
        logs)           cmd_mcp_logs "$@" ;;
        status)         cmd_mcp_status "$@" ;;
        install-custom) cmd_mcp_install_custom "$@" ;;
        *)
            err "unknown mcp subcommand '$sub'"
            cmd_mcp_help >&2
            exit 1
            ;;
    esac
}

# --- net --------------------------------------------------------------------
#
# `harness net` manages the egress allowlist (a flat text file) and the
# per-service firewall override JSON. Subcommands:
#
#   list     show allowlist hosts (annotated pull/push)
#   allow    add a host (with optional --git-push)
#   deny     remove a host
#   edit     open the allowlist in $EDITOR
#   status   summarize allowlist + override state
#   open     mark a service as firewall-disabled (requires confirmation phrase)
#   close    drop firewall-disabled override for a service
#
# All mutators are atomic (temp + mv) and idempotent. After a mutation the
# user is reminded to run `harness restart` to materialize the change in
# running containers.

# Names of the core services any of which can be opened/closed. MCP services
# aren't in this list because they each have their own short-lived container
# and the overrides file is keyed by docker-compose service name; if a future
# MCP needs an opt-out we'd add it here.
net_known_services() {
    printf '%s\n' proxy ollama claude-agent opencode-agent
}

cmd_net_help() {
    cat <<'EOF'
harness net — manage the egress allowlist and per-service firewall overrides.

usage:
  harness net <subcommand> [args...]

subcommands:
  list                        show every host in the allowlist (pull/push)
  allow <host> [--git-push]   add a host. --git-push annotates it so
                                git push to that host is permitted.
  deny <host>                 remove a host from the allowlist.
  edit                        open the allowlist in $EDITOR.
  status                      summarize allowlist size + active overrides.
  open <service>              fully disable the firewall for one service.
                                Requires the typed phrase
                                'I understand the risks' on a TTY prompt.
  close <service>             drop the firewall-disabled override for
                                <service>. Restores the universal firewall.

services that accept open/close:
  proxy, ollama, claude-agent, opencode-agent

After any mutation, run `harness restart` to apply the change to running
containers. (`net open` only takes effect on the next start of that
container; `net allow/deny` is read at every container boot.)
EOF
}

# Resolve the editor for `net edit`, in priority order. Falls back to vi.
net_pick_editor() {
    if [[ -n "${VISUAL:-}" ]]; then
        printf '%s' "$VISUAL"
    elif [[ -n "${EDITOR:-}" ]]; then
        printf '%s' "$EDITOR"
    else
        printf 'vi'
    fi
}

cmd_net_list() {
    load_net_helpers
    if [[ ! -f "$allowlist_path" ]]; then
        err "$allowlist_path does not exist; run install.sh or copy .harness-allowlist.example"
        exit 1
    fi
    printf '%-50s %s\n' "HOST" "MODE"
    netlib_list_hosts | awk -F '\t' '{ printf "%-50s %s\n", $1, $2 }'
}

cmd_net_allow() {
    load_net_helpers
    local host="" git_push=0
    while (( $# > 0 )); do
        case "$1" in
            --git-push) git_push=1 ;;
            -*) err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$host" ]]; then host="$1"
                else err "unexpected extra argument '$1'"; exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$host" ]]; then
        err "usage: harness net allow <host> [--git-push]"
        exit 1
    fi
    local normalized
    if ! normalized=$(netlib_validate_host "$host"); then
        err "invalid host '$host' (allowed: lowercase letters, digits, '.', '-')"
        exit 1
    fi
    if netlib_has_host "$normalized"; then
        # Already present — only act if we need to upgrade pull -> push.
        local mode
        mode=$(netlib_list_hosts | awk -v h="$normalized" -F '\t' '$1 == h { print $2; exit }')
        if (( git_push )) && [[ "$mode" == "pull" ]]; then
            netlib_add_host "$normalized" "1"
            echo "upgraded $normalized to allow git push"
        else
            echo "$normalized already on allowlist (mode: $mode)"
        fi
    else
        netlib_add_host "$normalized" "$git_push"
        if (( git_push )); then
            echo "added $normalized (git push allowed)"
        else
            echo "added $normalized"
        fi
    fi
    echo "next: 'harness restart' to apply to running containers"
}

cmd_net_deny() {
    load_net_helpers
    local host="${1:-}"
    if [[ -z "$host" ]]; then
        err "usage: harness net deny <host>"
        exit 1
    fi
    local normalized
    if ! normalized=$(netlib_validate_host "$host"); then
        err "invalid host '$host'"
        exit 1
    fi
    if ! netlib_has_host "$normalized"; then
        err "$normalized is not on the allowlist"
        exit 1
    fi
    netlib_remove_host "$normalized"
    echo "removed $normalized"
    echo "next: 'harness restart' to apply to running containers"
}

cmd_net_edit() {
    if [[ ! -f "$allowlist_path" ]]; then
        err "$allowlist_path does not exist; run install.sh or copy .harness-allowlist.example"
        exit 1
    fi
    local editor
    editor=$(net_pick_editor)
    "$editor" "$allowlist_path"
    echo "next: 'harness restart' to apply changes"
}

cmd_net_status() {
    load_net_helpers
    printf 'allowlist:\n'
    if [[ -f "$allowlist_path" ]]; then
        local total push_count
        total=$(netlib_list_hosts | wc -l | tr -d ' ')
        push_count=$(netlib_list_pushable | wc -l | tr -d ' ')
        printf '  path:        %s\n' "$allowlist_path"
        printf '  hosts:       %s (%s pull-only, %s push-enabled)\n' \
            "$total" "$((total - push_count))" "$push_count"
    else
        printf '  path:        %s (missing)\n' "$allowlist_path"
    fi
    printf '\noverrides:\n'
    printf '  path:        %s\n' "$net_overrides_path"
    if [[ -f "$net_overrides_path" ]]; then
        local open_list
        open_list=$(netlib_overrides_open_services | paste -sd ',' -)
        if [[ -z "$open_list" ]]; then
            printf '  open:        (none)\n'
        else
            printf '  open:        %s\n' "$open_list"
            printf '  WARNING:     these services have unrestricted egress.\n'
        fi
    else
        printf '  open:        (none — no overrides file)\n'
    fi
}

# Confirm by typed phrase. Reads from /dev/tty so confirmation is impossible
# to slip past in scripts. The phrase MUST match exactly (case-sensitive,
# no extra whitespace beyond the readline-stripped trailing newline).
net_confirm_phrase() {
    local expected="$1"
    if [[ ! -t 0 || ! -t 1 ]]; then
        # On a non-TTY stdin/stdout we still need /dev/tty to actually exist,
        # otherwise we can't ask the user. Refuse rather than blindly proceed.
        if [[ ! -e /dev/tty ]]; then
            err "non-interactive shell without /dev/tty; refusing to disable firewall"
            exit 1
        fi
    fi
    printf 'To confirm, type the following phrase exactly:\n' >&2
    printf '  %s\n' "$expected" >&2
    printf '> ' >&2
    local typed=""
    if ! IFS= read -r typed </dev/tty; then
        err "no input received"
        exit 1
    fi
    if [[ "$typed" != "$expected" ]]; then
        err "phrase did not match — aborting"
        exit 1
    fi
}

cmd_net_open() {
    load_net_helpers
    local svc="${1:-}"; shift || true
    local reason="${1:-}"
    if [[ -z "$svc" ]]; then
        err "usage: harness net open <service> [reason]"
        err "       services: $(net_known_services | paste -sd, -)"
        exit 1
    fi
    if ! net_known_services | grep -qx -- "$svc"; then
        err "unknown service '$svc' (services: $(net_known_services | paste -sd, -))"
        exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        err "jq is required for net open/close; install it on the host"
        exit 1
    fi
    if netlib_overrides_is_open "$svc"; then
        echo "$svc already firewall-disabled"
        return 0
    fi

    cat >&2 <<EOF
This will disable the egress firewall for the '$svc' service entirely.
Once applied, that container will have unrestricted outbound network and
can talk to any host on the internet.

Use this only if you have an explicit reason that the universal allowlist
cannot cover (e.g. an upstream API on a CDN with rotating IPs). Prefer
'harness net allow <host>' wherever possible.

EOF
    net_confirm_phrase "I understand the risks"
    netlib_overrides_open "$svc" "$reason"
    echo "opened: $svc (firewall disabled)"
    echo "next: 'harness restart' to apply (the next start of '$svc' picks it up)"
}

cmd_net_close() {
    load_net_helpers
    local svc="${1:-}"
    if [[ -z "$svc" ]]; then
        err "usage: harness net close <service>"
        exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        err "jq is required for net open/close; install it on the host"
        exit 1
    fi
    if [[ ! -f "$net_overrides_path" ]] || ! netlib_overrides_is_open "$svc"; then
        echo "$svc has no firewall-disabled override (nothing to close)"
        return 0
    fi
    netlib_overrides_close "$svc"
    echo "closed: $svc (firewall re-enabled)"
    echo "next: 'harness restart' to apply"
}

cmd_net() {
    local sub="${1:-help}"
    if [[ $# -gt 0 ]]; then shift; fi
    case "$sub" in
        help|-h|--help) cmd_net_help ;;
        list)           cmd_net_list   "$@" ;;
        allow)          cmd_net_allow  "$@" ;;
        deny)           cmd_net_deny   "$@" ;;
        edit)           cmd_net_edit   "$@" ;;
        status)         cmd_net_status "$@" ;;
        open)           cmd_net_open   "$@" ;;
        close)          cmd_net_close  "$@" ;;
        *)
            err "unknown net subcommand '$sub'"
            cmd_net_help >&2
            exit 1
            ;;
    esac
}

# --- claude-statusline-config -----------------------------------------------
#
# Run the ccstatusline TUI inside an ephemeral claude container without
# bringing up ollama or the proxy — the statusline binary doesn't need either.
# We mount only the agent home so changes persist and the universal firewall
# allowlist is still applied.
cmd_claude_statusline_config() {
    require_docker
    ensure_dirs
    local image="harness-claude-agent:latest"
    if ! docker image inspect "$image" >/dev/null 2>&1; then
        # Build the image without starting the rest of the stack. We use
        # `docker compose build` so the agent profile/path resolution matches
        # `harness start` exactly.
        echo "harness: building $image (one-time)..."
        compose --profile agent build claude-agent
    fi
    local agent_config_dir="$state_root/agent/claude"
    mkdir -p "$agent_config_dir"

    local tty_flag="-it"
    [[ -t 0 ]] || tty_flag="-i"

    # Network: harness-net IS NOT required for the configurator (it doesn't
    # talk to ollama). We attach to it anyway so the same firewall rules apply
    # — `ccstatusline` is a local TUI but consistency wins.
    local network="${project_name}_harness-net"

    # If the network doesn't exist (services have never been started), use
    # bridge — the configurator still works without ollama/proxy reachability.
    if ! docker network inspect "$network" >/dev/null 2>&1; then
        network="bridge"
    fi

    exec docker run --rm "$tty_flag" \
        --user 0:0 \
        --network "$network" \
        --cap-add NET_ADMIN \
        --cap-add NET_RAW \
        -e "HOST_UID=$(id -u)" \
        -e "HOST_GID=$(id -g)" \
        -e "HARNESS_PRINT_MODE=1" \
        -v "$agent_config_dir:/home/harness" \
        -v "$allowlist_path:/etc/harness/allowlist:ro" \
        --entrypoint /bin/bash \
        "$image" \
        -c '
            set -e
            # Reuse the entrypoints uid-remap + skel-seed paths so the home
            # is in the same shape as a real claude launch. We invoke them
            # explicitly because we override --entrypoint.
            if [[ "$(id -u)" == "0" && -n "${HOST_UID:-}" && -n "${HOST_GID:-}" ]]; then
                if [[ -x /usr/local/bin/init-firewall.sh ]]; then
                    /usr/local/bin/init-firewall.sh || true
                fi
                current_uid=$(id -u harness 2>/dev/null || echo "")
                current_gid=$(id -g harness 2>/dev/null || echo "")
                if [[ "${current_uid}" != "${HOST_UID}" || "${current_gid}" != "${HOST_GID}" ]]; then
                    groupmod -g "${HOST_GID}" -o harness 2>/dev/null \
                        || groupadd -g "${HOST_GID}" -o harness
                    usermod -u "${HOST_UID}" -g "${HOST_GID}" -o harness
                    chown -R "${HOST_UID}:${HOST_GID}" /home/harness 2>/dev/null || true
                fi
                exec gosu harness /bin/bash -lc "
                    if [[ ! -f \$HOME/.harness-home-initialized ]]; then
                        cp -an /etc/skel/harness/. \$HOME/ 2>/dev/null || true
                        touch \$HOME/.harness-home-initialized
                    fi
                    exec ccstatusline
                "
            fi
            # Already non-root (test path).
            if [[ ! -f $HOME/.harness-home-initialized ]]; then
                cp -an /etc/skel/harness/. $HOME/ 2>/dev/null || true
                touch $HOME/.harness-home-initialized
            fi
            exec ccstatusline
        '
}

# --- doctor -----------------------------------------------------------------
#
# Read-only runtime diagnostics. Each section runs a fixed set of checks;
# every check prints one line: <symbol> <name> <detail>. A summary footer
# reports counts. Exit 0 if zero errors, 1 otherwise. Warnings don't fail.
#
# Implementation notes:
#   - Each check is wrapped to never abort doctor (e.g. via `|| true`).
#   - Runtime probes that exec into containers are bounded with `timeout 3`
#     so a slow / hung container can't stall the whole report.
#   - Output is plain text + one ANSI color per status. No box-drawing.

declare -i doctor_errors=0
declare -i doctor_warnings=0

doctor_section() {
    printf '\n[%s]\n' "$1"
}

doctor_check() {
    local status="$1" name="$2" detail="${3:-}"
    local symbol color
    case "$status" in
        ok)   symbol='✓'; color='\033[0;32m' ;;
        fail) symbol='✗'; color='\033[0;31m'; doctor_errors=$((doctor_errors+1)) ;;
        warn) symbol='⚠'; color='\033[0;33m'; doctor_warnings=$((doctor_warnings+1)) ;;
        skip) symbol='–'; color='\033[0;90m' ;;
        *)    symbol='?'; color='' ;;
    esac
    printf '  %b%s%b %-22s %s\n' "$color" "$symbol" '\033[0m' "$name" "$detail"
}

# Redact a secret to "abcd...wxyz" (first 4 + last 4) when long enough,
# else "***". For empty or short values returns "***".
doctor_redact() {
    local v="${1:-}"
    if [[ -z "$v" ]]; then
        printf '***'
        return
    fi
    if (( ${#v} >= 12 )); then
        printf '%s...%s' "${v:0:4}" "${v: -4}"
    else
        printf '***'
    fi
}

# Fetch the Health.Status string from a compose service (empty string if
# the service or container can't be inspected). Never aborts on failure.
doctor_health_of() {
    local svc="$1"
    local cid
    cid=$(compose ps -q "$svc" 2>/dev/null || true)
    if [[ -z "$cid" ]]; then
        printf 'absent'
        return
    fi
    docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || printf 'unknown'
}

cmd_doctor() {
    doctor_errors=0
    doctor_warnings=0

    # ---------------- [deps] ----------------
    doctor_section deps
    if docker info >/dev/null 2>&1; then
        doctor_check ok "docker daemon" "reachable"
    else
        doctor_check fail "docker daemon" "not reachable; is the daemon running?"
    fi

    if docker compose version >/dev/null 2>&1; then
        local v
        v=$(docker compose version 2>/dev/null | head -1)
        doctor_check ok "docker compose" "${v}"
    else
        doctor_check fail "docker compose" "v2 not available"
    fi

    if command -v git >/dev/null 2>&1; then
        local gv
        gv=$(git --version 2>/dev/null | head -1)
        doctor_check ok "git" "${gv}"
    else
        doctor_check fail "git" "not found on PATH"
    fi

    # ---------------- [install] -------------
    doctor_section install
    doctor_check ok "install root" "$install_root"

    if [[ -d "$clone_dir/.git" ]]; then
        local commit branch dirty_count detail
        commit=$(git -C "$clone_dir" describe --always 2>/dev/null || echo "?")
        branch=$(git -C "$clone_dir" branch --show-current 2>/dev/null || echo "?")
        dirty_count=$(git -C "$clone_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$dirty_count" == "0" ]]; then
            detail="${commit} on ${branch} (clean)"
        else
            detail="${commit} on ${branch} (${dirty_count} dirty)"
        fi
        doctor_check ok "clone" "$detail"
    else
        doctor_check fail "clone" "$clone_dir is not a git repo"
    fi

    local local_bin="$HOME/.local/bin/harness"
    if [[ -L "$local_bin" ]]; then
        local target
        target=$(readlink -f "$local_bin" 2>/dev/null || true)
        if [[ "$target" == "$real_self" ]]; then
            doctor_check ok "harness symlink" "$local_bin -> $real_self"
        else
            doctor_check warn "harness symlink" "points to ${target:-?} (expected $real_self)"
        fi
    else
        doctor_check warn "harness symlink" "$local_bin missing; reinstall to add"
    fi

    case ":$PATH:" in
        *":$HOME/.local/bin:"*)
            doctor_check ok "PATH" "\$HOME/.local/bin present"
            ;;
        *)
            doctor_check warn "PATH" "\$HOME/.local/bin not in PATH"
            ;;
    esac

    # ---------------- [config] --------------
    doctor_section config
    if [[ ! -f "$env_file" ]]; then
        doctor_check fail ".env" "$env_file missing"
    elif [[ ! -r "$env_file" ]]; then
        doctor_check fail ".env" "$env_file not readable"
    else
        doctor_check ok ".env" "$env_file"

        if [[ -n "${PROXY_API_URL:-}" ]]; then
            doctor_check ok "PROXY_API_URL" "$PROXY_API_URL"
        else
            doctor_check fail "PROXY_API_URL" "unset"
        fi

        if [[ -n "${PROXY_API_KEY:-}" ]]; then
            doctor_check ok "PROXY_API_KEY" "$(doctor_redact "$PROXY_API_KEY")"
        else
            doctor_check fail "PROXY_API_KEY" "unset"
        fi

        if [[ -n "${PROXY_API_MODEL:-}" ]]; then
            doctor_check ok "PROXY_API_MODEL" "$PROXY_API_MODEL"
        else
            doctor_check fail "PROXY_API_MODEL" "unset"
        fi

        if [[ -n "${OLLAMA_VERSION:-}" ]]; then
            doctor_check ok "OLLAMA_VERSION" "$OLLAMA_VERSION"
        else
            doctor_check fail "OLLAMA_VERSION" "unset"
        fi

        doctor_check ok "OLLAMA_AGENT_MODEL" "$agent_model"
    fi

    # ---------------- [network] -------------
    doctor_section network
    if [[ -f "$allowlist_path" ]]; then
        load_net_helpers
        local total push_count
        total=$(netlib_list_hosts | wc -l | tr -d ' ')
        push_count=$(netlib_list_pushable | wc -l | tr -d ' ')
        doctor_check ok "allowlist" "$allowlist_path ($total hosts, $push_count push-enabled)"

        # Cross-check PROXY_API_URL hostname against the allowlist — this is
        # the single most common misconfiguration (entry missing or typo'd)
        # and the firewall guardrail will refuse to start the proxy without
        # it. Surfacing it here gives the user a fast diagnosis.
        if [[ -n "${PROXY_API_URL:-}" ]]; then
            local proxy_host
            proxy_host=$(printf '%s' "$PROXY_API_URL" | awk -F'[/:]' '{print $4}')
            if [[ -n "$proxy_host" && "$proxy_host" == *.* ]]; then
                if netlib_has_host "$proxy_host"; then
                    doctor_check ok "PROXY_API_URL host" "$proxy_host on allowlist"
                else
                    doctor_check fail "PROXY_API_URL host" \
                        "$proxy_host NOT on allowlist (proxy will refuse to start)"
                fi
            fi
        fi
    else
        doctor_check fail "allowlist" "$allowlist_path missing"
    fi

    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        load_net_helpers
        local open_list
        open_list=$(netlib_overrides_open_services | paste -sd ',' -)
        if [[ -z "$open_list" ]]; then
            doctor_check ok "overrides" "$net_overrides_path (no open services)"
        else
            doctor_check warn "overrides" "$open_list firewall-disabled — unrestricted egress"
        fi
    else
        doctor_check ok "overrides" "no per-service overrides"
    fi

    # ---------------- [storage] -------------
    doctor_section storage
    local d
    for d in output agent/claude agent/opencode ollama-data; do
        local path="$state_root/$d"
        if [[ -d "$path" && -w "$path" ]]; then
            doctor_check ok "state/$d" "writable"
        elif [[ -d "$path" ]]; then
            doctor_check fail "state/$d" "exists but not writable"
        else
            doctor_check fail "state/$d" "missing ($path)"
        fi
    done
    # mcp/ is only required if any MCPs have been enabled. If the dir
    # exists but is empty, that's fine — it's auto-created by ensure_dirs.
    if [[ -d "$mcp_active_dir" ]]; then
        if any_mcp_active; then
            if [[ -w "$mcp_active_dir" ]]; then
                doctor_check ok "mcp" "writable; $(list_active_entries | wc -l | tr -d ' ') entries"
            else
                doctor_check fail "mcp" "exists but not writable ($mcp_active_dir)"
            fi
        else
            doctor_check ok "mcp" "no entries enabled"
        fi
    else
        doctor_check ok "mcp" "no entries enabled"
    fi

    # ---------------- [runtime] -------------
    doctor_section runtime
    local network="${project_name}_harness-net"
    local network_ok=0
    if docker network inspect "$network" >/dev/null 2>&1; then
        doctor_check ok "network" "$network"
        network_ok=1
    else
        doctor_check warn "network" "$network not present (services not running)"
    fi

    if (( network_ok )); then
        local ollama_status proxy_status
        ollama_status=$(doctor_health_of ollama)
        proxy_status=$(doctor_health_of proxy)

        case "$ollama_status" in
            healthy)        doctor_check ok   "ollama" "healthy" ;;
            absent)         doctor_check warn "ollama" "no container for project ($project_name)" ;;
            none)           doctor_check warn "ollama" "running but no healthcheck reported" ;;
            *)              doctor_check warn "ollama" "$ollama_status" ;;
        esac

        case "$proxy_status" in
            healthy)        doctor_check ok   "proxy" "healthy" ;;
            absent)         doctor_check warn "proxy" "no container for project ($project_name)" ;;
            none)           doctor_check warn "proxy" "running but no healthcheck reported" ;;
            *)              doctor_check warn "proxy" "$proxy_status" ;;
        esac

        # Stub model + proxy /health probes only meaningful if ollama is up.
        if [[ "$ollama_status" == "healthy" ]]; then
            local ollama_cid
            ollama_cid=$(compose ps -q ollama 2>/dev/null || true)
            if [[ -n "$ollama_cid" ]]; then
                local show_out
                show_out=$(timeout 3 docker exec "$ollama_cid" \
                    curl -sf -X POST -H 'Content-Type: application/json' \
                    -d "{\"name\":\"${agent_model}\"}" \
                    http://127.0.0.1:11434/api/show 2>/dev/null || true)
                if [[ -n "$show_out" ]] && grep -qi 'remote_host' <<<"$show_out"; then
                    doctor_check ok   "stub model" "$agent_model registered with remote_host"
                else
                    doctor_check warn "stub model" "$agent_model not registered yet"
                fi

                if timeout 3 docker exec "$ollama_cid" \
                    curl -sf "http://proxy:${PROXY_PORT:-8000}/health" >/dev/null 2>&1; then
                    doctor_check ok   "proxy /health" "reachable from ollama"
                else
                    doctor_check warn "proxy /health" "not reachable from ollama"
                fi
            else
                doctor_check skip "stub model" "ollama container id not found"
                doctor_check skip "proxy /health" "ollama container id not found"
            fi
        else
            doctor_check skip "stub model" "ollama not healthy"
            doctor_check skip "proxy /health" "ollama not healthy"
        fi
    else
        doctor_check skip "ollama" "services not running"
        doctor_check skip "proxy" "services not running"
        doctor_check skip "stub model" "services not running"
        doctor_check skip "proxy /health" "services not running"
    fi

    # ---------------- [images] --------------
    doctor_section images
    local img
    for img in \
        "harness-ollama:${OLLAMA_VERSION:-0.21.2}" \
        "harness-proxy:latest" \
        "harness-claude-agent:latest" \
        "harness-opencode-agent:latest"
    do
        if docker image inspect "$img" >/dev/null 2>&1; then
            doctor_check ok "$(printf '%s' "$img" | cut -d: -f1)" "$img present"
        else
            doctor_check warn "$(printf '%s' "$img" | cut -d: -f1)" "$img missing — run 'harness start' to build"
        fi
    done

    # ---------------- [mcp] -----------------
    #
    # Emitted whenever any MCP is installed (even if all are disabled), so
    # the user can see at a glance which MCPs are around and what state
    # they're in. For each entry we surface enabled/disabled and runtime
    # status. A misbehaving MCP warns rather than fails (the harness is
    # still usable without that MCP).
    local any_installed=0 entry_dir
    if [[ -d "$mcp_active_dir" ]]; then
        for entry_dir in "$mcp_active_dir"/*/; do
            [[ -f "$entry_dir/compose.yml" ]] || continue
            any_installed=1
            break
        done
    fi
    if (( any_installed )); then
        doctor_section mcp
        local name status detail
        while IFS= read -r entry_dir; do
            [[ -n "$entry_dir" ]] || continue
            name=$(basename "$entry_dir")
            if mcp_is_enabled "$name"; then
                status=$(mcp_runtime_status "$name")
                detail="enabled; ${status}"
                case "$status" in
                    *"(healthy)"|"running") doctor_check ok   "$name" "$detail" ;;
                    stopped)                doctor_check warn "$name" "$detail" ;;
                    *)                      doctor_check warn "$name" "$detail" ;;
                esac
            else
                doctor_check ok "$name" "disabled (installed)"
            fi
        done < <(list_active_entries)
    fi

    # ---------------- [agents] --------------
    doctor_section agents
    local running
    running=$(docker ps --filter "label=harness.agent=true" --format '{{.Names}}' 2>/dev/null | wc -l | tr -d ' ')
    doctor_check ok "running" "${running} agent container(s)"

    # ---------------- summary ---------------
    printf '\n%d errors, %d warnings\n' "$doctor_errors" "$doctor_warnings"
    if (( doctor_errors > 0 )); then
        return 1
    fi
    return 0
}

# --- dispatch ---------------------------------------------------------------

main() {
    local cmd="${1:-help}"
    if [[ $# -gt 0 ]]; then shift; fi

    case "$cmd" in
        help|-h|--help)             cmd_help ;;
        start)                      cmd_start ;;
        down)                       cmd_down ;;
        restart)                    cmd_restart ;;
        update)                     cmd_update ;;
        upgrade)                    cmd_upgrade "$@" ;;
        logs)                       cmd_logs "$@" ;;
        claude)                     run_agent claude   "$@" ;;
        opencode)                   run_agent opencode "$@" ;;
        claude-statusline-config)   cmd_claude_statusline_config "$@" ;;
        list)                       cmd_list ;;
        attach)                     cmd_attach "$@" ;;
        stop)                       cmd_stop "$@" ;;
        net)                        cmd_net "$@" ;;
        mcp)                        cmd_mcp "$@" ;;
        doctor)                     cmd_doctor ;;
        *)
            err "unknown command '$cmd'"
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
