#!/usr/bin/env bash
#
# harness — management entrypoint for the harness runtime.
#
# Layout assumed at runtime (the install root IS the git clone — they are
# the same directory):
#
#   <install-root>/                       # also the git clone
#     .git/                                # managed by 'harness update'
#     harness                              # this file (tracked)
#     docker-compose.yml                   # tracked
#     mcp-registry/                        # vetted MCP definitions (tracked)
#     ...
#     .env                                 # gitignored — user config
#     .harness-allowlist                   # gitignored — egress allowlist
#     state/                               # gitignored — runtime state
#       output/                            # bind-mounted into the proxy
#       agent/claude/                      # claude container's /home/harness
#       agent/opencode/                    # opencode container's /home/harness
#       mcp/<name>/                        # active MCP services
#       ollama-data/                       # ollama's blob store
#
# This script is symlinked into ~/.local/bin/harness by install.sh; we use
# realpath on $0 to resolve the script's true location independent of how
# it was invoked. The script's parent directory is both the clone and the
# install root.

set -euo pipefail

# --- self-locate ------------------------------------------------------------
#
# In production we resolve $0 through any symlinks (~/.local/bin/harness ->
# <install-root>/harness) to find the install root, which is also the git
# clone. Tests can override via HARNESS_INSTALL_ROOT — useful when the test
# layout uses symlinks that would otherwise collapse dirname into the real
# repo path.

real_self=$(realpath "$0")
# clone_dir is where the code lives (this script + docker-compose.yml + scripts/).
# install_root is where the user config (.env, .harness-allowlist) and runtime
# state (state/) live. In production these are the same directory: install.sh
# clones the repo and that clone IS the install root. Tests can override
# HARNESS_INSTALL_ROOT to point at a tmpdir while keeping clone_dir resolved
# to the real repo (via the script's realpath); without HARNESS_INSTALL_ROOT,
# install_root falls back to clone_dir and the layout is single-folder.
clone_dir=$(dirname "$real_self")
install_root="${HARNESS_INSTALL_ROOT:-$clone_dir}"
state_root="$install_root/state"
env_file="$install_root/.env"
runtime_override="$state_root/.harness-runtime.yml"

# Universal egress firewall allowlist. Bind-mounted into every harness
# container at /etc/harness/allowlist. install.sh seeds this from
# .harness-allowlist.example on a fresh install. Tests can override by
# setting HARNESS_ALLOWLIST_PATH.
allowlist_path="${HARNESS_ALLOWLIST_PATH:-$install_root/.harness-allowlist}"

# B3-MANAGED: net-overrides — JSON file holding per-service firewall opt-out
# state. Written by `harness net open/close <service>`; read by
# write_runtime_override to inject HARNESS_FIREWALL_DISABLED=1 env vars onto
# the matching services in the generated compose override. Tests can
# substitute their own path via HARNESS_NET_OVERRIDES_PATH.
net_overrides_path="${HARNESS_NET_OVERRIDES_PATH:-$install_root/.harness-net-overrides.json}"

# Tests can substitute their own registry by overriding HARNESS_REGISTRY_DIR.
# Defaults to the repo's bundled mcp-registry/ folder so users see the
# vetted set out-of-the-box.
registry_dir="${HARNESS_REGISTRY_DIR:-$clone_dir/mcp-registry}"
mcp_active_dir="$state_root/mcp"

# Project name is fixed by spec but overridable for tests so harness_test.sh
# can run without colliding with a real harness instance on the same daemon.
project_name="${HARNESS_PROJECT_NAME:-harness}"

# --- env loading ------------------------------------------------------------
#
# Source .env into this shell so we can read PUBLISH_OLLAMA_PORT,
# OLLAMA_AGENT_MODEL etc. for our own logic. docker compose gets the file
# separately via --env-file.

if [[ -f "$env_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$env_file"
    set +a
fi

agent_model="${OLLAMA_AGENT_MODEL:-harness}"

# --- net helpers (lazy load) ------------------------------------------------
#
# scripts/lib/net_helpers.sh is shared between the harness script and tests.
# We source it on first use so the no-op startup cost on commands that don't
# touch the network (e.g. `harness logs`) stays close to zero.

netlib_loaded=0
load_net_helpers() {
    if (( netlib_loaded )); then return 0; fi
    local lib="$clone_dir/scripts/lib/net_helpers.sh"
    if [[ ! -f "$lib" ]]; then
        err "internal: $lib is missing — broken install"
        exit 1
    fi
    # NETLIB_* must persist after `source` returns: the lib's functions read
    # them at call time, not at source time. The `VAR=val source` prefix
    # syntax only scopes the assignment to the source builtin itself.
    NETLIB_ALLOWLIST="$allowlist_path"
    NETLIB_OVERRIDES="$net_overrides_path"
    # shellcheck disable=SC1090
    source "$lib"
    netlib_loaded=1
}

# --- helpers ----------------------------------------------------------------

# Print to stderr in the standard `harness:` format.
err() {
    echo "harness: $*" >&2
}

# Fail with require_docker if the daemon isn't reachable.
require_docker() {
    if ! docker info >/dev/null 2>&1; then
        err "docker daemon is not reachable; is it running?"
        exit 1
    fi
}

# Create the install-root persistent directories if they don't exist.
ensure_dirs() {
    mkdir -p \
        "$state_root/output" \
        "$state_root/agent/claude" \
        "$state_root/agent/opencode" \
        "$state_root/ollama-data" \
        "$mcp_active_dir"
}

# Echo the -f arguments for every installed-and-enabled MCP compose snippet,
# one flag/value pair per line. Disabled MCPs are skipped (their dir stays
# but they don't get spliced into the compose stack).
mcp_compose_files() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 0
    fi
    local mcp_dir name
    for mcp_dir in "$mcp_active_dir"/*/; do
        [[ -f "$mcp_dir/compose.yml" ]] || continue
        name=$(basename "$mcp_dir")
        mcp_is_enabled "$name" || continue
        printf '%s\n' "-f" "$mcp_dir/compose.yml"
    done
}

# True if any installed MCP is currently enabled. Drives `harness start`'s
# decision to add `--profile mcp` to the up command.
any_mcp_active() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 1
    fi
    local mcp_dir name
    for mcp_dir in "$mcp_active_dir"/*/; do
        [[ -f "$mcp_dir/compose.yml" ]] || continue
        name=$(basename "$mcp_dir")
        mcp_is_enabled "$name" && return 0
    done
    return 1
}

# --- mcp state helpers ------------------------------------------------------
#
# State is tracked in <mcp_active_dir>/<name>/harness-meta.json:
#
#   {"enabled": true|false}
#
# Missing meta file == enabled (legacy default; pre-Phase-7a installs had
# no meta and were always treated as enabled). Writes are atomic via a
# temp file + mv so a crashed write can't leave half-parsed JSON.

mcp_meta_file() {
    printf '%s/%s/harness-meta.json' "$mcp_active_dir" "$1"
}

# True iff an MCP is installed (i.e., has compose.yml in the active tree).
mcp_is_installed() {
    [[ -f "$mcp_active_dir/$1/compose.yml" ]]
}

# True iff an MCP is enabled. Returns 0 when meta file is missing so legacy
# installs continue to behave as enabled.
mcp_is_enabled() {
    local name="$1"
    local meta
    meta=$(mcp_meta_file "$name")
    if [[ ! -f "$meta" ]]; then
        return 0
    fi
    if command -v jq >/dev/null 2>&1; then
        # NOTE: jq's `//` operator treats `false` as a missing value, so
        # `.enabled // true` returns true even when enabled is explicitly
        # false. Use the explicit null-check instead.
        local v
        v=$(jq -r 'if .enabled == null then "true" else (.enabled | tostring) end' "$meta" 2>/dev/null || echo "true")
        [[ "$v" == "true" ]]
    else
        # No jq — naive grep. Treat anything but an explicit false as enabled.
        ! grep -qE '"enabled"[[:space:]]*:[[:space:]]*false' "$meta"
    fi
}

# Set meta.enabled to "true" or "false" atomically. Creates the file if it
# doesn't already exist.
mcp_set_enabled() {
    local name="$1" value="$2"
    local meta
    meta=$(mcp_meta_file "$name")
    mkdir -p "$(dirname "$meta")"
    if command -v jq >/dev/null 2>&1 && [[ -f "$meta" ]]; then
        local tmp="${meta}.tmp.$$"
        if jq ".enabled = $value" "$meta" >"$tmp" 2>/dev/null; then
            mv "$tmp" "$meta"
            return 0
        fi
        rm -f "$tmp" 2>/dev/null || true
    fi
    # Fresh write or jq-less fallback.
    printf '{"enabled": %s}\n' "$value" >"$meta"
}

# Generate the runtime override file in-place. The file is rewritten on
# every invocation that runs `compose`, so toggling state via
# `harness net open/close` or PUBLISH_OLLAMA_PORT propagates immediately on
# the next `harness start` / `harness restart`.
#
# Two pieces of state can land in the override:
#   1. PUBLISH_OLLAMA_PORT — publishes ollama on a host port if non-empty.
#   2. .harness-net-overrides.json — per-service `firewall_disabled: true`
#      becomes an environment block on that service that the firewall
#      init-script honors as an opt-out.
#
# When both pieces are empty the override file is removed entirely (compose
# is invoked without the -f flag). This keeps `harness start` exactly as it
# was for installs that don't use either feature.
write_runtime_override() {
    # Build the body in a temp variable, write only if non-empty.
    local body=""

    # 1. PUBLISH_OLLAMA_PORT.
    if [[ -n "${PUBLISH_OLLAMA_PORT:-}" ]]; then
        body+="  ollama:"$'\n'
        body+="    ports:"$'\n'
        body+="      - \"${PUBLISH_OLLAMA_PORT}:11434\""$'\n'
    fi

    # 2. Per-service firewall opt-out.
    #
    # Every service that has firewall_disabled=true in the JSON gets a
    # `HARNESS_FIREWALL_DISABLED=1` env entry. The firewall init script
    # short-circuits on that variable. We never replace the service's
    # entrypoint or remove its cap_add — option A from the design docs.
    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        local svc
        while IFS= read -r svc; do
            [[ -z "$svc" ]] && continue
            body+="  ${svc}:"$'\n'
            body+="    environment:"$'\n'
            body+="      HARNESS_FIREWALL_DISABLED: \"1\""$'\n'
        done < <(jq -r '
            (.services // {})
            | to_entries[]
            | select(.value.firewall_disabled == true)
            | .key
        ' "$net_overrides_path" 2>/dev/null || true)
    fi

    if [[ -z "$body" ]]; then
        rm -f "$runtime_override"
        return 0
    fi
    mkdir -p "$(dirname "$runtime_override")"
    {
        echo "# Generated by harness; do not edit. Regenerated on every invocation."
        echo "services:"
        printf '%s' "$body"
    } >"$runtime_override"
}

# Wrap docker compose with all the args we always pass. INSTALL_ROOT is
# exported so MCP compose snippets can reference it via ${INSTALL_ROOT} for
# absolute volume paths — relative paths in -f-included files have
# inconsistent resolution semantics across docker compose versions.
compose() {
    write_runtime_override
    local args=(
        compose
        --project-name "$project_name"
        -f "$clone_dir/docker-compose.yml"
    )
    if [[ -f "$env_file" ]]; then
        args+=(--env-file "$env_file")
    fi
    if [[ -f "$runtime_override" ]]; then
        args+=(-f "$runtime_override")
    fi

    # Splice in any active MCP compose snippets. Each one assumes the
    # external network harness_harness-net is reachable; it is iff this
    # project's compose has already been brought up (see cmd_start).
    local mcp_arg
    while IFS= read -r mcp_arg; do
        [[ -n "$mcp_arg" ]] && args+=("$mcp_arg")
    done < <(mcp_compose_files)

    INSTALL_ROOT="$install_root" \
        HARNESS_ALLOWLIST_PATH="$allowlist_path" \
        docker "${args[@]}" "$@"
}

# Best-effort check: are ollama and proxy both running for this project?
services_up() {
    local ollama_id proxy_id
    ollama_id=$(compose ps -q ollama 2>/dev/null || true)
    proxy_id=$(compose ps -q proxy 2>/dev/null || true)
    [[ -n "$ollama_id" && -n "$proxy_id" ]] || return 1
    docker inspect -f '{{.State.Running}}' "$ollama_id" 2>/dev/null | grep -q '^true$' || return 1
    docker inspect -f '{{.State.Running}}' "$proxy_id"  2>/dev/null | grep -q '^true$' || return 1
    return 0
}

# Bring services up if they aren't already. Used before launching agents.
ensure_services_up() {
    if ! services_up; then
        echo "harness: services not running; starting..."
        cmd_start
    fi
}

# Deterministic short suffix for an agent container name. Two simultaneous
# agents in the same dir for the same tool would collide, so we hash the
# absolute mount path together with the tool name and take the first 8 chars.
agent_container_name() {
    local tool="$1"
    local mount="$2"
    local hash
    hash=$(printf '%s' "$tool:$mount" | sha256sum | cut -c1-8)
    printf 'harness-%s-%s' "$tool" "$hash"
}

# --- subcommands ------------------------------------------------------------

cmd_help() {
    cat <<'EOF'
harness — manage the harness runtime.

usage:
  harness <command> [args...]

commands:
  start                 build and bring up the ollama + proxy services
  down                  stop the ollama + proxy services (does NOT touch agents)
  restart               down + start (preserves per-invocation state)
  update                git pull --ff-only in the clone
  upgrade [flags]       pull + apply manifest-driven upgrade actions + restart
                        flags: --check (dry-run preview, no pull),
                               --no-prompt (skip apply confirmation),
                               --no-restart (apply without down/start)
  logs [service ...]    follow compose logs (no args = all services)
  claude  [args]        launch a claude-code agent in the current directory
  opencode [args]       launch an opencode agent in the current directory
  claude-statusline-config
                        run the ccstatusline configurator inside an ephemeral
                        claude container (no ollama/proxy needed)
  list                  list running harness agent containers
  attach [name]         re-attach to a running agent (picker if no name)
  stop   [name]         stop a running agent (picker if no name)
  net <subcmd>          manage the egress allowlist + per-service firewall
                        overrides (see 'harness net')
  mcp <subcmd>          manage long-running MCP services (see 'harness mcp')
  doctor                run runtime diagnostics (read-only)
  help                  show this help

agent flags:
  --yolo                pass auto-approve / skip-permissions to the agent
  --net                 disable the per-container firewall for THIS launch
                        only (full outbound network). Audit-logged on stderr.
  -p, --print "PROMPT"  headless single-shot invocation (no tmux); for claude
                        forwards its native -p flag, for opencode invokes
                        `opencode run` inside the container

'harness mcp' subcommands:
  mcp list                          list registry + installed entries and their state
  mcp install <name> [--force]      copy a registry MCP into the active tree
  mcp uninstall <name> [--force]    remove an installed MCP; data dir is preserved
  mcp enable <name>                 mark an installed MCP as auto-start
  mcp disable <name>                mark an installed MCP as do-not-auto-start
  mcp up <name>                     start an installed MCP container immediately
  mcp down <name>                   stop a running MCP container
  mcp logs <name>                   follow logs for a single MCP
  mcp status <name>                 per-MCP diagnostic
  mcp install-custom <path>         install a user-supplied MCP definition

notes:
  - 'harness down' stops services but leaves agent containers alone. Stop
    individual agents with 'harness stop'.
  - agent containers are named harness-<tool>-<hash> where the hash is
    derived from the working directory; relaunching from the same directory
    refuses to start a second copy and points you at 'harness attach'.
  - 'harness doctor' is diagnostic-only and never modifies state.
EOF
}

cmd_start() {
    require_docker
    ensure_dirs
    # Stop anything still running from a prior session so up brings a clean
    # state. The 2>/dev/null || true handles a fresh install where there's
    # nothing to stop. --remove-orphans is required because `compose` only
    # splices in -f for currently-enabled MCPs; a previously-enabled MCP that
    # was disabled becomes an orphan container without it and would never
    # actually go down on `harness start`.
    compose down --remove-orphans 2>/dev/null || true

    # HARNESS_NO_BUILD=1 skips the --build flag — useful when all needed
    # images already exist locally and re-running buildkit (which can pull
    # the build context from git for some MCPs, e.g. Serena) is wasteful
    # or impossible due to disk pressure. CI/integration tests pre-warm
    # the heavy images and then set this for the actual harness start.
    local build_flag=(--build)
    if [[ "${HARNESS_NO_BUILD:-0}" == "1" ]]; then
        build_flag=()
    fi

    # Active MCPs sit behind the `mcp` profile so they're only brought up
    # when something has been `harness mcp enable`d. Without --profile they
    # are silently ignored even though the -f file is on the compose argv.
    if any_mcp_active; then
        compose --profile mcp up -d "${build_flag[@]}"
    else
        compose up -d "${build_flag[@]}"
    fi
}

cmd_down() {
    require_docker
    compose down
}

# Restart core services. Convenience for the common "I edited .env or
# .harness-allowlist or .harness-net-overrides and want it picked up" loop.
# Implementation is exactly down + start so any future change to either is
# inherited automatically.
cmd_restart() {
    require_docker
    cmd_down
    cmd_start
}

cmd_update() {
    cd "$clone_dir"
    git pull --ff-only
}

cmd_upgrade() {
    local check_only=0
    local no_prompt=0
    local no_restart=0

    while (( $# > 0 )); do
        case "$1" in
            --check) check_only=1 ;;
            --no-prompt) no_prompt=1 ;;
            --no-restart) no_restart=1 ;;
            -h|--help)
                cat <<'EOF'
harness upgrade — pull latest code, apply upgrade actions, restart services.

usage:
  harness upgrade [--check] [--no-prompt] [--no-restart]

flags:
  --check         preview the upgrade actions in dry-run mode without
                  performing 'git pull' or any file modifications.
  --no-prompt     skip the interactive "apply?" prompt (CI / automation).
  --no-restart    apply upgrade actions but skip the down/start cycle.

The set of upgrade actions is driven by scripts/upgrade-manifest.json. Each
action describes how a file harness manages outside the repo (in your
install root) is brought forward when the repo changes — env vars, firewall
hostnames, ccstatusline keys, MCP registry definitions. User-set values
are NEVER overwritten.
EOF
                return 0
                ;;
            *)
                err "harness upgrade: unknown flag '$1'"
                exit 1
                ;;
        esac
        shift
    done

    require_docker

    if (( ! check_only )); then
        # HARNESS_UPGRADE_SKIP_PULL lets tests run the upgrade flow without
        # touching the real git remote. Production users should never set
        # this; without a pull the manifest reflects whatever is in the
        # already-cloned working tree.
        if [[ -z "${HARNESS_UPGRADE_SKIP_PULL:-}" ]]; then
            echo "harness: pulling latest..."
            if ! (cd "$clone_dir" && git pull --ff-only); then
                err "git pull failed; aborting upgrade"
                exit 1
            fi
        else
            echo "harness: skipping git pull (HARNESS_UPGRADE_SKIP_PULL set)"
        fi
    fi

    local manifest="$clone_dir/scripts/upgrade-manifest.json"
    local lib="$clone_dir/scripts/lib/upgrade_actions.sh"
    if [[ ! -f "$manifest" || ! -f "$lib" ]]; then
        err "no upgrade manifest or actions library found; falling back to legacy upgrade"
        if (( ! no_restart && ! check_only )); then
            cmd_down --remove-orphans 2>/dev/null || true
            cmd_start
        fi
        return 0
    fi

    if ! command -v jq >/dev/null 2>&1; then
        err "jq is required for 'harness upgrade'; install it and retry"
        exit 1
    fi

    # shellcheck disable=SC1090
    source "$lib"

    echo
    echo "Upgrade actions to apply:"
    jq -r '.actions[] | "  - \(.id): \(.description)"' "$manifest"
    jq -r '.registry_actions[]? | "  - \(.id) [\(.condition // "always")]: \(.description)"' "$manifest"
    echo

    if (( check_only )); then
        echo "(--check: dry-run; no changes will be made)"
        echo
        apply_upgrade_actions "$manifest" 1
        return 0
    fi

    if (( ! no_prompt )); then
        if [[ -t 0 ]]; then
            local ans
            read -rp "Apply these upgrade actions? [Y/n]: " ans
            case "${ans:-}" in
                ""|y|Y|yes|YES) ;;
                *) echo "harness: aborted by user"; return 1 ;;
            esac
        else
            err "non-interactive shell; pass --no-prompt to apply without confirmation"
            exit 1
        fi
    fi

    apply_upgrade_actions "$manifest" 0

    if (( ! no_restart )); then
        cmd_down --remove-orphans 2>/dev/null || true
        cmd_start
    fi
}

# Iterate the manifest's actions and registry_actions, dispatch to the
# right upgrade_* function in scripts/lib/upgrade_actions.sh, accumulate
# JSON results, and print a final summary.
#
# Args: <manifest_path> <dry_run_int>
apply_upgrade_actions() {
    local manifest="$1"
    local dry_run="$2"
    local results="[]"
    local failed=0

    # 1. Unconditional actions.
    while IFS= read -r action_json; do
        local id type src_rel src target_rel target strategy result rc
        id=$(jq -r '.id' <<<"$action_json")
        type=$(jq -r '.type' <<<"$action_json")
        src_rel=$(jq -r '.source' <<<"$action_json")
        src="$clone_dir/$src_rel"
        target_rel=$(jq -r '.target_relative' <<<"$action_json")
        target="$install_root/$target_rel"

        echo "[$id] $type" >&2

        result=""
        rc=0
        case "$type" in
            envfile_merge)
                result=$(upgrade_envfile_merge "$src" "$target" "$dry_run") || rc=$?
                ;;
            linefile_merge)
                result=$(upgrade_linefile_merge "$src" "$target" "$dry_run") || rc=$?
                ;;
            json_merge)
                strategy=$(jq -r '.strategy // "add_missing_keys"' <<<"$action_json")
                result=$(upgrade_json_merge "$src" "$target" "$strategy" "$dry_run") || rc=$?
                ;;
            *)
                err "[$id] unknown action type '$type'; skipping"
                continue
                ;;
        esac

        if (( rc != 0 )); then
            err "[$id] action returned rc=$rc; continuing"
            failed=$((failed+1))
        fi
        if [[ -n "$result" ]] && jq -e . <<<"$result" >/dev/null 2>&1; then
            results=$(jq --argjson r "$result" --arg id "$id" '. + [($r + {id: $id})]' <<<"$results")
        fi
    done < <(jq -c '.actions[]?' "$manifest")

    # 2. Registry actions (gated on `condition`).
    while IFS= read -r action_json; do
        local id type src_rel src target_rel target cond result rc
        id=$(jq -r '.id' <<<"$action_json")
        type=$(jq -r '.type' <<<"$action_json")
        src_rel=$(jq -r '.source' <<<"$action_json")
        src="$clone_dir/$src_rel"
        target_rel=$(jq -r '.target_relative' <<<"$action_json")
        target="$install_root/$target_rel"
        cond=$(jq -r '.condition // "always"' <<<"$action_json")

        if [[ "$cond" == "installed" && ! -d "$target" ]]; then
            echo "[$id] not installed; skipping" >&2
            continue
        fi

        local preserve_args=()
        local p
        while IFS= read -r p; do
            [[ -n "$p" ]] && preserve_args+=("$p")
        done < <(jq -r '.preserve[]?' <<<"$action_json")

        echo "[$id] $type" >&2

        result=""
        rc=0
        case "$type" in
            directory_overwrite)
                result=$(upgrade_directory_overwrite "$src" "$target" "$dry_run" "${preserve_args[@]}") || rc=$?
                ;;
            *)
                err "[$id] unknown registry action type '$type'; skipping"
                continue
                ;;
        esac

        if (( rc != 0 )); then
            err "[$id] action returned rc=$rc; continuing"
            failed=$((failed+1))
        fi
        if [[ -n "$result" ]] && jq -e . <<<"$result" >/dev/null 2>&1; then
            results=$(jq --argjson r "$result" --arg id "$id" '. + [($r + {id: $id})]' <<<"$results")
        fi
    done < <(jq -c '.registry_actions[]?' "$manifest")

    # 3. Forward-compat: warn if the manifest declares a newer schema
    # version than this runner knows how to handle. We only reach this
    # point after the loop above, so we've already applied any actions
    # that match types we recognize.
    local mver
    mver=$(jq -r '.version // 1' "$manifest" 2>/dev/null || echo 1)
    if [[ "$mver" =~ ^[0-9]+$ ]] && (( mver > 1 )); then
        err "manifest version=$mver is newer than this runner (1); applied known action types only"
    fi

    # 4. Summary.
    echo
    if (( dry_run )); then
        echo "Upgrade preview (--check, no changes applied):"
    else
        echo "Upgrade summary:"
    fi
    local n_total
    n_total=$(jq 'length' <<<"$results")
    if (( n_total == 0 )); then
        echo "  (no actions applied)"
        return 0
    fi
    # Per-action one-liner.
    jq -r '
        .[] | . as $r |
        ($r.added_keys // $r.added_lines // $r.added_paths // $r.files_updated // []) as $changes |
        ($r.warnings // []) as $warns |
        "  [\($r.id)] \($r.action): \($changes | length) change(s)" +
            (if ($warns | length) > 0 then ", \($warns | length) warning(s)" else "" end)
    ' <<<"$results"

    # Surface warnings and skipped/error reasons so the user sees them.
    local warns
    warns=$(jq -r '.[] | select((.warnings // []) | length > 0) | .warnings[] | "    WARN: " + .' <<<"$results")
    if [[ -n "$warns" ]]; then
        echo
        echo "$warns"
    fi
    local skipped
    skipped=$(jq -r '.[] | select(.skipped == true) | "    SKIPPED [" + (.id // "?") + "]: " + (.reason // "unknown")' <<<"$results")
    if [[ -n "$skipped" ]]; then
        echo
        echo "$skipped"
    fi

    if (( failed > 0 )); then
        err "${failed} action(s) failed; review log above"
        return 1
    fi
    return 0
}

cmd_logs() {
    require_docker
    compose logs -f "$@"
}

# Resolve per-tool image/config-dir/config-target for both run paths.
# Echoes three tab-separated fields on stdout: image, agent_config_dir,
# agent_config_target.
#
# The mount target is /home/harness for both tools — a full home rather
# than a per-CLI subdirectory — so things the user installs inside the
# agent (`pipx install graphifyy`, `pip install --user ...`) survive
# container restarts. Build-time skel content is restored on first run by
# the entrypoint via /etc/skel/harness/.
agent_runtime_paths() {
    local tool="$1"
    case "$tool" in
        claude)
            printf 'harness-claude-agent:latest\t%s\t%s\n' \
                "$state_root/agent/claude" "/home/harness"
            ;;
        opencode)
            printf 'harness-opencode-agent:latest\t%s\t%s\n' \
                "$state_root/agent/opencode" "/home/harness"
            ;;
        *)
            err "unknown tool '$tool'"
            exit 1
            ;;
    esac
}

# Write the merged MCP client config to <install-root>/state/agent/<tool>/.harness-mcp-servers.json
# so the entrypoint picks it up at startup. The harness emits a single
# claude-style shape — `{"mcpServers": {"<name>": {...}}}` — and the per-
# tool entrypoint translates to opencode's `mcp` block when needed. We
# rewrite this file on every agent launch so disabling an MCP propagates
# without leaving stale entries.
#
# When no MCPs are active, the file is removed so the entrypoint's "merge
# if file exists" path becomes a no-op. Without this, a previously enabled
# MCP would linger forever in the agent's config.
write_agent_mcp_config() {
    local tool="$1"
    local out_file="$state_root/agent/$tool/.harness-mcp-servers.json"

    # Collect every installed-and-enabled MCP's client-config.json. Disabled
    # MCPs are skipped so toggling enabled=false hides the entry from agents
    # without an uninstall. If jq is unavailable on the host or no entries
    # remain, skip the merge entirely and clean up any stale side file.
    local entries=()
    if [[ -d "$mcp_active_dir" ]]; then
        local mcp_dir name
        for mcp_dir in "$mcp_active_dir"/*/; do
            [[ -f "$mcp_dir/client-config.json" ]] || continue
            name=$(basename "$mcp_dir")
            mcp_is_enabled "$name" || continue
            entries+=("$mcp_dir/client-config.json")
        done
    fi

    if (( ${#entries[@]} == 0 )) || ! command -v jq >/dev/null 2>&1; then
        rm -f "$out_file" 2>/dev/null || true
        return 0
    fi

    # Reduce each {"mcpServers": {...}} into a single combined object.
    # Later entries win on key collision (predictable, alphabetic order).
    mkdir -p "$(dirname "$out_file")"
    if ! jq -s 'reduce .[] as $i ({"mcpServers": {}}; .mcpServers += ($i.mcpServers // {}))' \
        "${entries[@]}" >"$out_file" 2>/dev/null
    then
        # Bad json in one of the entries — don't let it stop the agent.
        rm -f "$out_file" 2>/dev/null || true
        err "warning: failed to merge MCP client configs; agent will start without MCP"
    fi
}

# Run an agent (claude or opencode) in the current directory.
#
# The container is started detached, with /workspace bind-mounted to $PWD
# and the agent's config dir bind-mounted from <install-root>/state/agent/<tool>.
# We then poll for the tmux session to become ready and exec into it.
#
# With -p / --print as the FIRST harness-level flag, we bypass tmux and run
# the agent in the foreground for single-shot scripted use.
run_agent() {
    local tool="$1"; shift

    # Parse --yolo, --net, and -p/--print. --yolo and --net can appear
    # anywhere; -p / --print is preserved in pass_args (claude consumes it as
    # its own headless flag; opencode's entrypoint detects it and switches to
    # `opencode run`).
    local yolo=0
    local print_mode=0
    local net_open=0
    local pass_args=()
    for arg in "$@"; do
        case "$arg" in
            --yolo)
                yolo=1
                ;;
            --net)
                # Per-invocation firewall opt-out. Loud audit log on stderr
                # so the choice shows up in scrollback / shell logs even if
                # the user runs the agent unattended.
                net_open=1
                err "WARNING: --net disables the egress firewall for this $tool launch."
                err "         The container will have unrestricted outbound network."
                ;;
            -p|--print)
                print_mode=1
                pass_args+=("$arg")
                ;;
            *)
                pass_args+=("$arg")
                ;;
        esac
    done

    require_docker
    ensure_services_up
    ensure_dirs

    local mount_path
    mount_path=$(realpath "$PWD")

    # Resolve per-tool paths.
    local image agent_config_dir agent_config_target
    IFS=$'\t' read -r image agent_config_dir agent_config_target < <(agent_runtime_paths "$tool")
    mkdir -p "$agent_config_dir"

    # Refresh the MCP side file before launch so the entrypoint sees the
    # current set of enabled MCPs. Done after mkdir so the dir exists.
    write_agent_mcp_config "$tool"

    # Verify the image exists. We don't auto-build agents on first run
    # because that's the job of `harness start`, which builds them via the
    # `agent` profile.
    if ! docker image inspect "$image" >/dev/null 2>&1; then
        err "image $image not found; run 'harness start' to build it"
        exit 1
    fi

    local network="${project_name}_harness-net"

    if (( print_mode )); then
        run_agent_print "$tool" "$yolo" "$net_open" "$mount_path" "$image" \
            "$agent_config_dir" "$agent_config_target" "$network" \
            "${pass_args[@]}"
    else
        run_agent_interactive "$tool" "$yolo" "$net_open" "$mount_path" "$image" \
            "$agent_config_dir" "$agent_config_target" "$network" \
            "${pass_args[@]}"
    fi
}

# Common -e flags shared between print and interactive launchers. Echoes
# one flag per line so the caller can splice them into a docker_args array.
agent_common_env() {
    local tool="$1"
    local yolo="$2"
    local net_open="${3:-0}"
    printf -- '-e\nHOST_UID=%s\n' "$(id -u)"
    printf -- '-e\nHOST_GID=%s\n' "$(id -g)"
    printf -- '-e\nHARNESS_YOLO=%s\n' "$yolo"
    printf -- '-e\nOLLAMA_AGENT_MODEL=%s\n' "$agent_model"
    if [[ "$net_open" == "1" ]]; then
        # Honored by firewall/init-firewall.sh — full opt-out. Setting it to
        # "0" explicitly when not opted-in is intentional: a stale value in
        # the environment can't accidentally re-enable the bypass.
        printf -- '-e\nHARNESS_FIREWALL_DISABLED=1\n'
    fi
    if [[ "$tool" == "claude" ]]; then
        printf -- '-e\nANTHROPIC_BASE_URL=http://ollama:11434\n'
        # AUTH_TOKEN (not API_KEY): claude-code's startup connectivity probe
        # to api.anthropic.com is gated to skip when AUTH_TOKEN is set; with
        # only API_KEY it hard-exits behind our default firewall.
        printf -- '-e\nANTHROPIC_AUTH_TOKEN=harness-dummy\n'
        printf -- '-e\nANTHROPIC_MODEL=%s\n' "$agent_model"
        printf -- '-e\nANTHROPIC_SMALL_FAST_MODEL=%s\n' "$agent_model"
    fi
}

# Build the env-flag array from agent_common_env's newline-delimited output.
collect_agent_env() {
    local tool="$1" yolo="$2" net_open="${3:-0}"
    local -a out=()
    while IFS= read -r line; do
        out+=("$line")
    done < <(agent_common_env "$tool" "$yolo" "$net_open")
    printf '%s\0' "${out[@]}"
}

run_agent_interactive() {
    local tool="$1" yolo="$2" net_open="$3" mount_path="$4" image="$5"
    local agent_config_dir="$6" agent_config_target="$7" network="$8"
    shift 8
    local pass_args=("$@")

    local cname
    cname=$(agent_container_name "$tool" "$mount_path")

    # Already running for this dir+tool? Tell the user to attach instead.
    if [[ -n "$(docker ps -q -f "name=^${cname}$" 2>/dev/null)" ]]; then
        err "$tool agent already running here ($cname)"
        err "use 'harness attach' to reconnect"
        exit 1
    fi

    # Clean up any stopped container with the same name (e.g. previous run
    # that exited but wasn't removed). Ignore errors.
    docker rm "$cname" >/dev/null 2>&1 || true

    # --user 0:0 overrides the image's USER harness directive so the
    # entrypoint can remap the harness uid/gid to the host caller before
    # gosu-dropping back to harness. Without this, the container runs as
    # harness uid 1000 directly and the remap block is bypassed (matching
    # the agent_test.sh path).
    local docker_args=(
        run -d
        --name "$cname"
        --user 0:0
        --network "$network"
        # The agent entrypoint runs init-firewall.sh as root before gosu-
        # dropping to harness; iptables/ipset need NET_ADMIN/NET_RAW.
        --cap-add NET_ADMIN
        --cap-add NET_RAW
    )

    local env_line
    while IFS= read -r -d '' env_line; do
        docker_args+=("$env_line")
    done < <(collect_agent_env "$tool" "$yolo" "$net_open")

    docker_args+=(
        -v "$mount_path:/workspace"
        -v "$agent_config_dir:$agent_config_target"
        # Universal firewall allowlist, read-only. The init script aborts the
        # container if this is missing.
        -v "$allowlist_path:/etc/harness/allowlist:ro"
        -w /workspace
        --label "harness.agent=true"
        --label "harness.tool=$tool"
        --label "harness.mount=$mount_path"
        "$image"
    )
    if (( ${#pass_args[@]} > 0 )); then
        docker_args+=("${pass_args[@]}")
    fi

    local cid
    cid=$(docker "${docker_args[@]}")

    # Poll for tmux readiness. The entrypoint takes a moment to start the
    # session; without this wait, exec races and fails. tmux is owned by
    # the harness user inside the container (the entrypoint does
    # `exec gosu harness ...` after the UID remap), so we exec as harness
    # rather than the container's default root — root's tmux client looks
    # at /tmp/tmux-0/default, which doesn't exist.
    local tries=40   # 40 * 0.5s = 20s ceiling
    while (( tries > 0 )); do
        if docker exec --user harness "$cid" tmux has-session -t harness-agent 2>/dev/null; then
            break
        fi
        if [[ -z "$(docker ps -q -f "id=$cid" 2>/dev/null)" ]]; then
            err "agent container exited before tmux session started"
            docker logs "$cname" 2>&1 | tail -30 >&2 || true
            exit 1
        fi
        sleep 0.5
        tries=$(( tries - 1 ))
    done
    if (( tries == 0 )); then
        err "tmux session not ready after 20s; check 'docker logs $cname'"
        exit 1
    fi

    exec docker exec -it --user harness "$cid" tmux attach -t harness-agent
}

# Headless single-shot agent invocation. No tmux, no detach, no labels (so
# it doesn't appear in `harness list`). Container is auto-removed on exit.
# stdin handling: -it if running on a TTY, -i otherwise — claude needs the
# TTY for some output formats but pipe-based callers shouldn't get a TTY.
run_agent_print() {
    local tool="$1" yolo="$2" net_open="$3" mount_path="$4" image="$5"
    local agent_config_dir="$6" agent_config_target="$7" network="$8"
    shift 8
    local pass_args=("$@")

    local tty_flag
    if [[ -t 0 ]]; then
        tty_flag="-it"
    else
        tty_flag="-i"
    fi

    local docker_args=(
        run --rm "$tty_flag"
        --user 0:0
        --network "$network"
        # See run_agent_interactive for the cap rationale.
        --cap-add NET_ADMIN
        --cap-add NET_RAW
    )

    local env_line
    while IFS= read -r -d '' env_line; do
        docker_args+=("$env_line")
    done < <(collect_agent_env "$tool" "$yolo" "$net_open")

    docker_args+=(
        -e "HARNESS_PRINT_MODE=1"
        -v "$mount_path:/workspace"
        -v "$agent_config_dir:$agent_config_target"
        -v "$allowlist_path:/etc/harness/allowlist:ro"
        -w /workspace
        "$image"
    )
    if (( ${#pass_args[@]} > 0 )); then
        docker_args+=("${pass_args[@]}")
    fi

    exec docker "${docker_args[@]}"
}

cmd_list() {
    require_docker
    local rows
    rows=$(docker ps \
        --filter "label=harness.agent=true" \
        --format '{{.Names}}\t{{.Label "harness.tool"}}\t{{.Label "harness.mount"}}\t{{.RunningFor}}')
    if [[ -z "$rows" ]]; then
        echo "no harness agents running"
        return 0
    fi
    {
        printf 'NAME\tTOOL\tMOUNT\tAGE\n'
        printf '%s\n' "$rows"
    } | column -t -s $'\t'
}

# List all running harness agents, returns lines: <name>\t<tool>\t<mount>.
list_agents_raw() {
    docker ps \
        --filter "label=harness.agent=true" \
        --format '{{.Names}}\t{{.Label "harness.tool"}}\t{{.Label "harness.mount"}}'
}

# Render an interactive picker over the supplied newline-delimited list of
# agents (each line: name\ttool\tmount). Reads stdin for the selection.
# Echoes the chosen name on stdout.
pick_agent() {
    local rows="$1"
    if [[ ! -t 0 ]]; then
        err "ambiguous; provide a name explicitly"
        exit 1
    fi
    echo "running harness agents:" >&2
    local i=0
    local -a names=()
    while IFS=$'\t' read -r name tool mount; do
        i=$(( i + 1 ))
        names+=("$name")
        printf '  %d) %s  [%s]  %s\n' "$i" "$name" "$tool" "$mount" >&2
    done <<<"$rows"
    local choice
    read -rp "select [1-$i]: " choice </dev/tty
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > i )); then
        err "invalid selection"
        exit 1
    fi
    printf '%s\n' "${names[$((choice - 1))]}"
}

cmd_attach() {
    require_docker
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        local mount_path
        mount_path=$(realpath "$PWD")
        # First try to find agents whose mount matches PWD.
        local here
        here=$(docker ps \
            --filter "label=harness.agent=true" \
            --filter "label=harness.mount=$mount_path" \
            --format '{{.Names}}\t{{.Label "harness.tool"}}\t{{.Label "harness.mount"}}')
        local count=0
        if [[ -n "$here" ]]; then
            count=$(printf '%s\n' "$here" | wc -l)
        fi
        if (( count == 1 )); then
            target=$(printf '%s' "$here" | cut -f1)
        elif (( count > 1 )); then
            target=$(pick_agent "$here")
        else
            local all
            all=$(list_agents_raw)
            if [[ -z "$all" ]]; then
                err "no harness agents running"
                exit 1
            fi
            target=$(pick_agent "$all")
        fi
    fi

    if [[ -z "$(docker ps -q -f "name=^${target}$" 2>/dev/null)" ]]; then
        err "no running container named '$target'"
        exit 1
    fi
    # tmux is owned by the harness user inside the container; see the
    # explanation in run_agent_interactive.
    exec docker exec -it --user harness "$target" tmux attach -t harness-agent
}

cmd_stop() {
    require_docker
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        local all
        all=$(list_agents_raw)
        if [[ -z "$all" ]]; then
            err "no harness agents running"
            exit 1
        fi
        local count
        count=$(printf '%s\n' "$all" | wc -l)
        if (( count == 1 )); then
            target=$(printf '%s' "$all" | cut -f1)
        else
            target=$(pick_agent "$all")
        fi
    fi

    docker stop "$target" >/dev/null
    docker rm "$target" >/dev/null 2>&1 || true
    echo "stopped: $target"
}

# --- mcp --------------------------------------------------------------------
#
# Long-running MCP services (Serena and friends) live in two parallel trees:
#
#   <repo>/mcp-registry/<name>/                # vetted definitions, source of truth
#   <install-root>/state/mcp/<name>/           # active copies; presence == enabled
#
# Enabling copies the registry entry into the active tree (preserving the
# upstream by-value, so the user can edit their copy without diverging the
# repo). Disabling removes everything except the optional `data/` dir,
# which holds per-MCP persistent state (indices, caches).

# Echo the registry entry directories that exist (one path per line). Names
# starting with `_` are reserved for fixtures (test entries) and excluded
# from the user-facing list view, but still resolvable by `enable`/`disable`
# for tests that target them by name.
list_registry_entries() {
    if [[ ! -d "$registry_dir" ]]; then
        return 0
    fi
    local d
    for d in "$registry_dir"/*/; do
        [[ -d "$d" ]] || continue
        printf '%s\n' "${d%/}"
    done
}

# Echo the active MCP entry directories that exist (one path per line).
list_active_entries() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 0
    fi
    local d
    for d in "$mcp_active_dir"/*/; do
        [[ -d "$d" ]] || continue
        printf '%s\n' "${d%/}"
    done
}

# Best-effort runtime status for a single MCP service: parses
# `docker compose ps` to find a container whose service name matches the
# active entry. Container-name matching is brittle by design — MCP composes
# don't have a uniform service name — so we report the first active service
# we find inside the snippet.
mcp_runtime_status() {
    local name="$1"
    local compose_file="$mcp_active_dir/$name/compose.yml"
    [[ -f "$compose_file" ]] || { printf -- '-'; return; }
    if ! docker info >/dev/null 2>&1; then
        printf -- 'docker-down'; return
    fi
    # Pull the first service name out of the compose snippet. Naive YAML —
    # the snippet shape is constrained (we control the registry) so this is
    # deliberately not a full parser.
    local svc
    svc=$(awk '
        /^services:/ { in_svc=1; next }
        in_svc && /^[A-Za-z]/ { in_svc=0 }
        in_svc && /^  [A-Za-z][A-Za-z0-9_-]*:/ {
            sub(/:.*$/, "")
            sub(/^[[:space:]]+/, "")
            print
            exit
        }
    ' "$compose_file")
    if [[ -z "$svc" ]]; then
        printf 'unknown'
        return
    fi
    local cid
    cid=$(compose ps -q "$svc" 2>/dev/null || true)
    if [[ -z "$cid" ]]; then
        printf 'stopped'
        return
    fi
    local running health
    running=$(docker inspect -f '{{.State.Running}}' "$cid" 2>/dev/null || echo "")
    health=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || echo "")
    if [[ "$running" != "true" ]]; then
        printf 'stopped'
        return
    fi
    case "$health" in
        healthy)   printf 'running (healthy)' ;;
        unhealthy) printf 'running (unhealthy)' ;;
        starting)  printf 'starting' ;;
        none|"")   printf 'running' ;;
        *)         printf 'running (%s)' "$health" ;;
    esac
}

cmd_mcp_help() {
    cat <<'EOF'
harness mcp — manage long-running MCP services.

usage:
  harness mcp <subcommand> [args...]

subcommands:
  list                          show registry + installed entries with state
  install <name> [--force]      copy a registry entry into the active tree
  uninstall <name> [--force]    remove an installed entry; data/ is preserved
  enable <name>                 mark an installed MCP as auto-start (default
                                  on install). 'harness start' brings it up.
  disable <name>                mark an installed MCP as do-not-auto-start.
                                  Container is left alone; use 'mcp down' to
                                  stop one immediately or 'mcp up' to start
                                  one without flipping its enable state.
  up <name>                     start an installed MCP container immediately
  down <name>                   stop an installed MCP container
  logs <name>                   follow logs for a single MCP
  status <name>                 per-MCP diagnostic
  install-custom <path>         install a user-supplied MCP definition

deprecated (still works, with a warning to stderr):
  enable <name>                 when <name> is in the registry but not yet
                                  installed, this is the Phase 6 verb —
                                  forwarded to 'install <name>'.
  disable <name> --force        forwarded to 'uninstall <name> --force'.

state diagram:
  available --install--> installed-enabled <-> installed-disabled
                                          \--uninstall--> available

After install/uninstall/enable/disable, run 'harness start' (or
'harness upgrade') to materialize the change in the running compose stack.
'mcp up' / 'mcp down' bypass the start/down cycle and act on a single MCP.
EOF
}

cmd_mcp_list() {
    local printed_header=0
    local seen_names=()

    # Walk the registry first (canonical order) and decorate with active state.
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        # Hide reserved test fixture names from user output.
        [[ "$name" =~ ^_ ]] && continue
        if (( printed_header == 0 )); then
            printf '%-20s %-22s %s\n' "NAME" "STATE" "STATUS"
            printed_header=1
        fi
        local state status
        if mcp_is_installed "$name"; then
            if mcp_is_enabled "$name"; then
                state="installed-enabled"
            else
                state="installed-disabled"
            fi
            status=$(mcp_runtime_status "$name")
        else
            state="available"
            status="-"
        fi
        printf '%-20s %-22s %s\n' "$name" "$state" "$status"
        seen_names+=("$name")
    done < <(list_registry_entries)

    # Surface anything in the active tree that doesn't have a registry entry
    # (custom installs, locally-edited copies).
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        [[ "$name" =~ ^_ ]] && continue
        local already=0 s
        for s in "${seen_names[@]}"; do
            if [[ "$s" == "$name" ]]; then already=1; break; fi
        done
        (( already )) && continue
        if (( printed_header == 0 )); then
            printf '%-20s %-22s %s\n' "NAME" "STATE" "STATUS"
            printed_header=1
        fi
        local state status
        if mcp_is_enabled "$name"; then
            state="installed-enabled"
        else
            state="installed-disabled"
        fi
        status=$(mcp_runtime_status "$name")
        printf '%-20s %-22s %s\n' "${name} (custom)" "$state" "$status"
    done < <(list_active_entries)

    if (( printed_header == 0 )); then
        echo "no MCP entries (registry: $registry_dir)"
    fi
}

# Names of available registry entries, comma-separated, for error messages.
mcp_registry_names_csv() {
    local out=""
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        [[ "$name" =~ ^_ ]] && continue
        if [[ -z "$out" ]]; then
            out="$name"
        else
            out="$out, $name"
        fi
    done < <(list_registry_entries)
    printf '%s' "${out:-(none)}"
}

# Echo the service names declared in an MCP's compose snippet, one per line.
# Empty output means we couldn't enumerate (missing file or compose error).
mcp_services_of() {
    local name="$1"
    local compose_file="$mcp_active_dir/$name/compose.yml"
    [[ -f "$compose_file" ]] || return 0
    docker compose -f "$compose_file" --profile mcp config --services 2>/dev/null || true
}

# install: registry -> active tree. Default state is enabled.
#
# B3-MANAGED: mcp-active-tree — <install-root>/state/mcp/<name>/. Created by this
# function from mcp-registry/<name>/. `harness upgrade` runs a per-MCP
# `directory_overwrite` registry action (gated on `condition: installed`)
# that refreshes compose.yml, client-config.json, README.md, etc., while
# preserving harness-meta.json (user enable state) and data/ (indexed
# state). See scripts/upgrade-manifest.json's `registry_actions` block.
cmd_mcp_install() {
    local force=0 name=""
    while (( $# > 0 )); do
        case "$1" in
            --force) force=1 ;;
            -*)      err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp install <name> [--force]"
        exit 1
    fi

    local src="$registry_dir/$name"
    if [[ ! -d "$src" ]]; then
        err "unknown MCP '$name'; available: $(mcp_registry_names_csv)"
        exit 1
    fi
    if [[ ! -f "$src/compose.yml" ]]; then
        err "registry entry '$name' is missing compose.yml"
        exit 1
    fi

    local dest="$mcp_active_dir/$name"
    # "Already installed" means compose.yml is present. After uninstall the
    # directory may still exist (data/ is preserved), so checking only for
    # the directory would refuse a clean re-install after an uninstall.
    if mcp_is_installed "$name" && (( ! force )); then
        err "$name is already installed (use --force to overwrite)"
        exit 1
    fi

    mkdir -p "$mcp_active_dir"
    if (( force )) && [[ -d "$dest" ]]; then
        # Wipe everything except data/ so persistent state survives a force-
        # reinstall. data is sacred.
        local f
        for f in "$dest"/*; do
            [[ -e "$f" ]] || continue
            if [[ "$(basename "$f")" == "data" ]]; then
                continue
            fi
            rm -rf "$f"
        done
    fi
    mkdir -p "$dest"
    local f
    for f in "$src"/* "$src"/.[!.]*; do
        [[ -e "$f" ]] || continue
        # The .template file is a registry-side default for harness-meta.json
        # that we materialize into the active tree below — copy as the real
        # filename rather than leaving the .template extension lying around.
        local base
        base=$(basename "$f")
        if [[ "$base" == "harness-meta.json.template" ]]; then
            cp -a "$f" "$dest/harness-meta.json"
            continue
        fi
        cp -a "$f" "$dest/"
    done
    mkdir -p "$dest/data"
    # Always force enabled=true on a fresh install regardless of what (if
    # anything) the template said. allowed_domains and any other registry-side
    # defaults are preserved by the copy above.
    mcp_set_enabled "$name" "true"

    cat <<EOF
installed: $name (from $src)
state: installed-enabled
data: $dest/data
next:
  run 'harness start' (or 'harness upgrade') to bring up the service.
  agents launched after that will see this MCP in their config.
EOF

    # If the MCP's harness-meta.json declared allowed_domains, surface them
    # as a recommendation. We DO NOT auto-add — the user should make the
    # network-policy decision deliberately. Empty arrays produce no output.
    local installed_meta="$dest/harness-meta.json"
    if [[ -f "$installed_meta" ]] && command -v jq >/dev/null 2>&1; then
        local domains
        domains=$(jq -r '(.allowed_domains // []) | .[]' "$installed_meta" 2>/dev/null || true)
        if [[ -n "$domains" ]]; then
            echo
            echo "this MCP recommends allowlisting the following domains for outbound traffic:"
            local d
            while IFS= read -r d; do
                [[ -z "$d" ]] && continue
                echo "  $d"
            done <<<"$domains"
            echo
            echo "to add them, run:"
            while IFS= read -r d; do
                [[ -z "$d" ]] && continue
                echo "  harness net allow $d"
            done <<<"$domains"
        fi
    fi
}

# uninstall: stop containers, remove active tree (preserve data/).
cmd_mcp_uninstall() {
    local force=0 name=""
    while (( $# > 0 )); do
        case "$1" in
            --force) force=1 ;;
            -*)      err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp uninstall <name> [--force]"
        exit 1
    fi

    local dest="$mcp_active_dir/$name"
    if [[ ! -d "$dest" ]]; then
        err "$name is not installed"
        exit 1
    fi

    if (( ! force )); then
        local ans
        printf 'this will stop and remove the active config for %s. ' "$name" >&2
        printf 'data dir at %s/data will be preserved. continue? [y/N]: ' "$dest" >&2
        if [[ -t 0 ]]; then
            read -r ans </dev/tty
        else
            err "non-interactive shell; pass --force to confirm"
            exit 1
        fi
        case "${ans:-}" in
            y|Y|yes|YES) ;;
            *) echo "aborted." >&2; exit 0 ;;
        esac
    fi

    # Stop and remove the MCP's containers if running. Enumerate services
    # via `compose config --services` (--profile mcp required to see them)
    # and `compose rm -sf` each one through the full project compose so we
    # don't disturb the core services or other MCPs.
    if [[ -f "$dest/compose.yml" ]] && docker info >/dev/null 2>&1; then
        local svc
        while IFS= read -r svc; do
            [[ -z "$svc" ]] && continue
            compose --profile mcp rm -sf "$svc" 2>/dev/null || true
        done < <(mcp_services_of "$name")
    fi

    local f
    for f in "$dest"/* "$dest"/.[!.]*; do
        [[ -e "$f" ]] || continue
        if [[ "$(basename "$f")" == "data" ]]; then
            continue
        fi
        rm -rf "$f"
    done
    if [[ ! -d "$dest/data" ]]; then
        rmdir "$dest" 2>/dev/null || true
    fi

    echo "uninstalled: $name"
    if [[ -d "$dest/data" ]]; then
        echo "data preserved at: $dest/data"
    fi
}

# enable: mark installed MCP as auto-start.
# Phase 6 alias: when <name> is in the registry but NOT yet installed, the
# Phase 6 'enable' verb meant 'install'. We forward, with a warning.
cmd_mcp_enable() {
    local name=""
    while (( $# > 0 )); do
        case "$1" in
            -*) err "unknown flag '$1' (did you mean 'harness mcp install $1'?)"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp enable <name>"
        exit 1
    fi

    if ! mcp_is_installed "$name"; then
        if [[ -d "$registry_dir/$name" ]]; then
            err "DEPRECATED: 'harness mcp enable <name>' for not-yet-installed MCPs is the Phase 6 form. Use 'harness mcp install <name>'. Forwarding..."
            cmd_mcp_install "$name"
            return
        fi
        err "unknown MCP '$name'; available: $(mcp_registry_names_csv)"
        exit 1
    fi

    mcp_set_enabled "$name" "true"
    echo "enabled: $name"
    echo "next: 'harness start' (or 'harness upgrade') to bring it up."
}

# disable: mark installed MCP as do-not-auto-start.
# Phase 6 alias: --force triggers the old uninstall semantics.
cmd_mcp_disable() {
    local force=0 name=""
    while (( $# > 0 )); do
        case "$1" in
            --force) force=1 ;;
            -*) err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp disable <name>"
        exit 1
    fi

    if (( force )); then
        err "DEPRECATED: 'harness mcp disable --force' is the Phase 6 form. Use 'harness mcp uninstall <name> --force'. Forwarding..."
        cmd_mcp_uninstall --force "$name"
        return
    fi

    if ! mcp_is_installed "$name"; then
        err "$name is not installed"
        exit 1
    fi
    mcp_set_enabled "$name" "false"
    echo "disabled: $name (still installed; data + config preserved)"
    echo "next: 'harness mcp down $name' to stop a running container, or"
    echo "      'harness start' to apply the change to the running stack."
}

# up: start an installed MCP's containers regardless of enabled flag.
cmd_mcp_up() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "usage: harness mcp up <name>"
        exit 1
    fi
    if ! mcp_is_installed "$name"; then
        err "$name is not installed"
        exit 1
    fi
    require_docker

    local svc_list=()
    local svc
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        svc_list+=("$svc")
    done < <(mcp_services_of "$name")
    if (( ${#svc_list[@]} == 0 )); then
        err "could not enumerate services in $mcp_active_dir/$name/compose.yml"
        exit 1
    fi

    # Force-add this MCP's compose file to the argv even if it's disabled —
    # `compose` (the wrapper) only adds enabled MCPs through mcp_compose_files.
    write_runtime_override
    local args=(
        compose
        --project-name "$project_name"
        -f "$clone_dir/docker-compose.yml"
    )
    if [[ -f "$env_file" ]]; then args+=(--env-file "$env_file"); fi
    if [[ -f "$runtime_override" ]]; then args+=(-f "$runtime_override"); fi
    # Other enabled MCPs (so their networks/volumes resolve consistently).
    local mcp_arg
    while IFS= read -r mcp_arg; do
        [[ -n "$mcp_arg" ]] && args+=("$mcp_arg")
    done < <(mcp_compose_files)
    # Force this MCP in, even if disabled.
    if ! mcp_is_enabled "$name"; then
        args+=(-f "$mcp_active_dir/$name/compose.yml")
    fi
    args+=(--profile mcp up -d)
    args+=("${svc_list[@]}")
    INSTALL_ROOT="$install_root" \
        HARNESS_ALLOWLIST_PATH="$allowlist_path" \
        docker "${args[@]}"
    echo "up: $name"
}

