cmd_start() {
    require_runtime_config
    require_docker
    ensure_dirs

    # Probe the upstream auth state before bringing up the stack. A locked
    # key reads as a confusing chain of failures once agents start hitting
    # the proxy; surfacing it here lets the user click through the unlock
    # URL before any container has tried to talk to the upstream.
    # HARNESS_SKIP_AUTH_PROBE=1 bypasses for CI/automation that doesn't
    # have real upstream credentials.
    if [[ "${HARNESS_SKIP_AUTH_PROBE:-0}" != "1" ]]; then
        local probe_rc=0
        _probe_upstream_auth || probe_rc=$?
        if (( probe_rc == 1 )); then
            return 1
        fi
        # rc=2 means warn-and-continue; already logged.
    fi

    # Stop anything still running from a prior session so up brings a clean
    # state. The 2>/dev/null || true handles a fresh install where there's
    # nothing to stop. --remove-orphans is required because `compose` only
    # splices in -f for currently-enabled MCPs; a previously-enabled MCP that
    # was disabled becomes an orphan container without it and would never
    # actually go down on `harness start`.
    compose down --remove-orphans 2>/dev/null || true

    # HARNESS_NO_BUILD=1 skips the --build flag — useful when all needed
    # images already exist locally and re-running buildkit (which can pull
    # the build context from git for some MCPs, e.g. Serena) is wasteful
    # or impossible due to disk pressure. CI/integration tests pre-warm
    # the heavy images and then set this for the actual harness start.
    local build_flag=(--build)
    if [[ "${HARNESS_NO_BUILD:-0}" == "1" ]]; then
        build_flag=()
    fi

    # Active MCPs sit behind the `mcp` profile so they're only brought up
    # when something has been `harness mcp enable`d. Without --profile they
    # are silently ignored even though the -f file is on the compose argv.
    local up_rc=0
    if any_mcp_active; then
        compose --profile mcp up -d "${build_flag[@]}" || up_rc=$?
    else
        compose up -d "${build_flag[@]}" || up_rc=$?
    fi

    # When compose fails (typically a service container failing its
    # healthcheck), print actionable diagnostics. Without this hint the
    # user sees only "dependency failed to start: container ... is
    # unhealthy" with no guidance on how to look inside.
    if (( up_rc != 0 )); then
        echo
        echo "[harness] start failed (exit $up_rc). Common causes:"
        echo "  - PROXY_API_URL or PROXY_API_KEY missing/wrong in .env"
        echo "  - Upstream API hostname not in .harness-allowlist"
        echo "  - Stale Docker resources (try: harness down)"
        echo
        echo "To diagnose, run:"
        echo "  harness preflight                   # validates configuration"
        echo "  docker logs harness-proxy-1         # what the proxy printed on startup"
        echo "  docker logs harness-ollama-1        # what ollama printed on startup"
        return $up_rc
    fi
}

cmd_down() {
    require_docker

    # Stop any agent containers attached to this project's network. They were
    # started by `harness claude`/`opencode` via direct docker run (not
    # compose), so compose doesn't know about them — but they hold the
    # network in use, blocking compose's network teardown and forcing the
    # user to clean up by hand.
    local agent_cids
    agent_cids=$(docker ps -q \
        --filter "label=harness.project=$project_name" \
        --filter "label=harness.agent=true" 2>/dev/null)
    if [[ -n "$agent_cids" ]]; then
        local agent_names
        agent_names=$(docker ps \
            --filter "label=harness.project=$project_name" \
            --filter "label=harness.agent=true" \
            --format '{{.Names}}' | tr '\n' ' ')
        echo "[harness] stopping agent containers: $agent_names"
        # shellcheck disable=SC2086
        docker stop $agent_cids >/dev/null 2>&1 || true
        # shellcheck disable=SC2086
        docker rm -f $agent_cids >/dev/null 2>&1 || true
    fi

    compose down "$@"
}

# Restart core services. Convenience for the common "I edited .env or
# .harness-allowlist or .harness-net-overrides and want it picked up" loop.
# Implementation is exactly down + start so any future change to either is
# inherited automatically.
cmd_restart() {
    require_docker
    cmd_down
    cmd_start
}

cmd_update() {
    cd "$clone_dir"
    git pull --ff-only
}

cmd_upgrade() {
    local check_only=0
    local no_prompt=0
    local no_restart=0
    local rebuild=0

    while (( $# > 0 )); do
        case "$1" in
            --check) check_only=1 ;;
            --no-prompt) no_prompt=1 ;;
            --no-restart) no_restart=1 ;;
            --rebuild) rebuild=1 ;;
            -h|--help)
                cat <<'EOF'
harness upgrade — pull latest code, apply upgrade actions, rebuild images,
                  restart services.

usage:
  harness upgrade [--check] [--no-prompt] [--no-restart] [--rebuild]

flags:
  --check         preview the upgrade actions in dry-run mode without
                  performing 'git pull' or any file modifications.
  --no-prompt     skip the interactive "apply?" prompt (CI / automation).
  --no-restart    apply upgrade actions but skip the build/down/start cycle.
  --rebuild       force a clean rebuild (compose build --no-cache). Slower
                  but bypasses any cache-poisoning from earlier failed
                  builds.

The set of upgrade actions is driven by scripts/upgrade-manifest.json. Each
action describes how a file harness manages inside the install root (which
is the same directory as the clone, post-B4) is brought forward when the
repo changes — env vars, firewall hostnames, ccstatusline keys, MCP
registry definitions. User-set values are NEVER overwritten.

Image rebuild is run between manifest-apply and start so image-level
changes (Dockerfile, proxy.py, agent entrypoint) take effect on upgrade.
EOF
                return 0
                ;;
            *)
                err "harness upgrade: unknown flag '$1'"
                exit 1
                ;;
        esac
        shift
    done

    require_docker

    if (( ! check_only )); then
        # HARNESS_UPGRADE_SKIP_PULL lets tests run the upgrade flow without
        # touching the real git remote. Production users should never set
        # this; without a pull the manifest reflects whatever is in the
        # already-cloned working tree.
        if [[ -z "${HARNESS_UPGRADE_SKIP_PULL:-}" ]]; then
            echo "harness: pulling latest..."
            if ! (cd "$clone_dir" && git pull --ff-only); then
                err "git pull failed; aborting upgrade"
                exit 1
            fi
        else
            echo "harness: skipping git pull (HARNESS_UPGRADE_SKIP_PULL set)"
        fi
    fi

    local manifest="$clone_dir/scripts/upgrade-manifest.json"
    local lib="$clone_dir/scripts/lib/upgrade_actions.sh"
    if [[ ! -f "$manifest" || ! -f "$lib" ]]; then
        err "no upgrade manifest or actions library found; falling back to legacy upgrade"
        if (( ! no_restart && ! check_only )); then
            cmd_down --remove-orphans 2>/dev/null || true
            cmd_start
        fi
        return 0
    fi

    # shellcheck disable=SC1090
    source "$lib"

    echo
    echo "Upgrade actions to apply:"
    harness_jq -r '.actions[] | "  - \(.id): \(.description)"' "$manifest"
    harness_jq -r '.registry_actions[]? | "  - \(.id) [\(.condition // "always")]: \(.description)"' "$manifest"
    echo

    if (( check_only )); then
        echo "(--check: dry-run; no changes will be made)"
        echo
        apply_upgrade_actions "$manifest" 1
        return 0
    fi

    if (( ! no_prompt )); then
        if [[ -t 0 ]]; then
            local ans
            read -rp "Apply these upgrade actions? [Y/n]: " ans
            case "${ans:-}" in
                ""|y|Y|yes|YES) ;;
                *) echo "harness: aborted by user"; return 1 ;;
            esac
        else
            err "non-interactive shell; pass --no-prompt to apply without confirmation"
            exit 1
        fi
    fi

    apply_upgrade_actions "$manifest" 0

    if (( ! no_restart )); then
        cmd_down --remove-orphans 2>/dev/null || true

        # Rebuild images so image-level changes (Dockerfile, proxy.py, agent
        # entrypoint) take effect. Without this, the existing local images
        # are reused and the user runs stale containers without realizing.
        # --rebuild adds --no-cache for a force-rebuild; otherwise BuildKit
        # uses its layer cache and only changed layers are re-run.
        local build_args=()
        if (( rebuild )); then
            build_args+=(--no-cache)
        fi
        echo "[harness] rebuilding container images..."
        # --profile agent ensures the agent service (which is profile-gated
        # in docker-compose.yml) is included in the rebuild set; without it,
        # only default-profile services (proxy, ollama) get rebuilt and
        # image-level changes to agents/Dockerfile or agents/entrypoint.sh
        # silently slip past the upgrade.
        if ! compose --profile agent build "${build_args[@]}"; then
            err "compose build failed; aborting upgrade"
            return 1
        fi

        # Force docker compose to re-resolve every bind-mount source path
        # (notably .harness-allowlist) before `cmd_start` issues `compose up`.
        # Why: on Windows + Docker Desktop, the linefile_merge step in
        # apply_upgrade_actions writes to .harness-allowlist via a tmp-file +
        # atomic-mv. The Git-Bash-side mv lands the new inode on disk
        # immediately, but Docker Desktop's bind-mount source lookup runs
        # against its WSL2/virtiofs filesystem cache, which may still hold a
        # stale "missing" entry for that path right after the rename. When
        # the next `compose up` then mounts the source, Docker sees nothing
        # there, auto-creates an empty *directory* at the bind source, and
        # the proxy/ollama containers boot but fail their firewall init
        # with "allowlist file not found at /etc/harness/allowlist". A bare
        # `compose config` triggers compose's path-resolution pass and gives
        # the daemon a chance to refresh that cache before the real `up`.
        # On Linux this is just YAML re-validation — effectively a no-op.
        compose config >/dev/null 2>&1 || true

        # The 'compose --profile agent build' above already built everything;
        # skip cmd_start's redundant --build pass.
        HARNESS_NO_BUILD=1 cmd_start
    fi
}

# Iterate the manifest's actions and registry_actions, dispatch to the
# right upgrade_* function in scripts/lib/upgrade_actions.sh, accumulate
# JSON results, and print a final summary.
#
# Args: <manifest_path> <dry_run_int>
apply_upgrade_actions() {
    local manifest="$1"
    local dry_run="$2"
    local results="[]"
    local failed=0

    # 1. Unconditional actions.
    while IFS= read -r action_json; do
        action_json=${action_json%$'\r'}
        local id type src_rel src target_rel target strategy result rc
        id=$(_upg_strip_cr "$(harness_jq -r '.id' <<<"$action_json")")
        type=$(_upg_strip_cr "$(harness_jq -r '.type' <<<"$action_json")")
        src_rel=$(_upg_strip_cr "$(harness_jq -r '.source' <<<"$action_json")")
        src="$clone_dir/$src_rel"
        target_rel=$(_upg_strip_cr "$(harness_jq -r '.target_relative' <<<"$action_json")")
        target="$install_root/$target_rel"

        echo "[$id] $type" >&2

        result=""
        rc=0
        case "$type" in
            envfile_merge)
                result=$(upgrade_envfile_merge "$src" "$target" "$dry_run") || rc=$?
                ;;
            linefile_merge)
                result=$(upgrade_linefile_merge "$src" "$target" "$dry_run") || rc=$?
                ;;
            json_merge)
                strategy=$(_upg_strip_cr "$(harness_jq -r '.strategy // "add_missing_keys"' <<<"$action_json")")
                result=$(upgrade_json_merge "$src" "$target" "$strategy" "$dry_run") || rc=$?
                ;;
            *)
                err "[$id] unknown action type '$type'; skipping"
                continue
                ;;
        esac

        if (( rc != 0 )); then
            err "[$id] action returned rc=$rc; continuing"
            failed=$((failed+1))
        fi
        result=$(_upg_strip_cr "$result")
        if [[ -n "$result" ]] && harness_jq -e . <<<"$result" >/dev/null 2>&1; then
            results=$(_upg_strip_cr "$(harness_jq --argjson r "$result" --arg id "$id" '. + [($r + {id: $id})]' <<<"$results")")
        fi
    done < <(harness_jq -c '.actions[]?' "$manifest")

    # 2. Registry actions (gated on `condition`).
    while IFS= read -r action_json; do
        action_json=${action_json%$'\r'}
        local id type src_rel src target_rel target cond result rc
        id=$(_upg_strip_cr "$(harness_jq -r '.id' <<<"$action_json")")
        type=$(_upg_strip_cr "$(harness_jq -r '.type' <<<"$action_json")")
        src_rel=$(_upg_strip_cr "$(harness_jq -r '.source' <<<"$action_json")")
        src="$clone_dir/$src_rel"
        target_rel=$(_upg_strip_cr "$(harness_jq -r '.target_relative' <<<"$action_json")")
        target="$install_root/$target_rel"
        cond=$(_upg_strip_cr "$(harness_jq -r '.condition // "always"' <<<"$action_json")")

        if [[ "$cond" == "installed" && ! -d "$target" ]]; then
            echo "[$id] not installed; skipping" >&2
            continue
        fi

        local preserve_args=()
        local p
        while IFS= read -r p; do
            p=${p%$'\r'}
            [[ -n "$p" ]] && preserve_args+=("$p")
        done < <(harness_jq -r '.preserve[]?' <<<"$action_json")

        echo "[$id] $type" >&2

        result=""
        rc=0
        case "$type" in
            directory_overwrite)
                result=$(upgrade_directory_overwrite "$src" "$target" "$dry_run" "${preserve_args[@]}") || rc=$?
                ;;
            *)
                err "[$id] unknown registry action type '$type'; skipping"
                continue
                ;;
        esac

        if (( rc != 0 )); then
            err "[$id] action returned rc=$rc; continuing"
            failed=$((failed+1))
        fi
        result=$(_upg_strip_cr "$result")
        if [[ -n "$result" ]] && harness_jq -e . <<<"$result" >/dev/null 2>&1; then
            results=$(_upg_strip_cr "$(harness_jq --argjson r "$result" --arg id "$id" '. + [($r + {id: $id})]' <<<"$results")")
        fi
    done < <(harness_jq -c '.registry_actions[]?' "$manifest")

    # 3. Forward-compat: warn if the manifest declares a newer schema
    # version than this runner knows how to handle. We only reach this
    # point after the loop above, so we've already applied any actions
    # that match types we recognize.
    local mver
    mver=$(_upg_strip_cr "$(harness_jq -r '.version // 1' "$manifest" 2>/dev/null || echo 1)")
    if [[ "$mver" =~ ^[0-9]+$ ]] && (( mver > 1 )); then
        err "manifest version=$mver is newer than this runner (1); applied known action types only"
    fi

    # 4. Summary.
    echo
    if (( dry_run )); then
        echo "Upgrade preview (--check, no changes applied):"
    else
        echo "Upgrade summary:"
    fi
    local n_total
    n_total=$(_upg_strip_cr "$(harness_jq 'length' <<<"$results")")
    if (( n_total == 0 )); then
        echo "  (no actions applied)"
        return 0
    fi
    # Per-action one-liner.
    harness_jq -r '
        .[] | . as $r |
        ($r.added_keys // $r.added_lines // $r.added_paths // $r.files_updated // []) as $changes |
        ($r.warnings // []) as $warns |
        "  [\($r.id)] \($r.action): \($changes | length) change(s)" +
            (if ($warns | length) > 0 then ", \($warns | length) warning(s)" else "" end)
    ' <<<"$results"

    # Surface warnings and skipped/error reasons so the user sees them.
    local warns
    warns=$(harness_jq -r '.[] | select((.warnings // []) | length > 0) | .warnings[] | "    WARN: " + .' <<<"$results")
    if [[ -n "$warns" ]]; then
        echo
        echo "$warns"
    fi
    local skipped
    skipped=$(harness_jq -r '.[] | select(.skipped == true) | "    SKIPPED [" + (.id // "?") + "]: " + (.reason // "unknown")' <<<"$results")
    if [[ -n "$skipped" ]]; then
        echo
        echo "$skipped"
    fi

    # An "action failure" here is rc=1 from an upgrade_* helper, which in
    # practice means a single merge couldn't apply (target had user
    # customization, jq merge filter returned an error, etc.) — the per-
    # action JSON line records a `skipped: true` with a `reason`, and the
    # SKIPPED summary block above prints those for the user. The upgrade
    # itself is not in a broken state. Don't print scary "N action(s) failed"
    # text and don't propagate a nonzero rc to cmd_upgrade.
    if (( failed > 0 )); then
        echo "[harness] ${failed} action(s) skipped (likely safe — file already matches or has user customization). Upgrade continues." >&2
    fi
    return 0
}

cmd_logs() {
    require_docker
    compose logs -f "$@"
}

# Single shared agent image and home directory.
#
# After the unification (Phase 13a), claude and opencode share both the
# image and the persistent home. The entrypoint dispatches on a mode arg
# (claude/opencode/shell) so user-installed skills and tools (pipx,
# pip --user, ~/.gitconfig, etc.) are visible across all modes. Build-time
# skel content is restored on first run by the entrypoint via
# /etc/skel/harness/.
agent_image() { printf 'harness-agent:latest'; }
agent_home_dir() { printf '%s' "$state_root/agent/home"; }

# Write the merged MCP client config to <install-root>/state/agent/home/
# .harness-mcp-servers.json so the entrypoint picks it up at startup. The
# harness emits a single claude-style shape —
# `{"mcpServers": {"<name>": {...}}}` — and the entrypoint translates to
# opencode's `mcp` block when needed. We rewrite this file on every agent
# launch so disabling an MCP propagates without leaving stale entries.
#
# When no MCPs are active, the file is removed so the entrypoint's "merge
# if file exists" path becomes a no-op. Without this, a previously enabled
# MCP would linger forever in the agent's config.
write_agent_mcp_config() {
    local out_file
    out_file="$(agent_home_dir)/.harness-mcp-servers.json"

    # Collect every installed-and-enabled MCP's client-config.json. Disabled
    # MCPs are skipped so toggling enabled=false hides the entry from agents
    # without an uninstall. If jq is unavailable on the host or no entries
    # remain, skip the merge entirely and clean up any stale side file.
    local entries=()
    if [[ -d "$mcp_active_dir" ]]; then
        local mcp_dir name
        for mcp_dir in "$mcp_active_dir"/*/; do
            [[ -f "$mcp_dir/client-config.json" ]] || continue
            name=$(basename "$mcp_dir")
            mcp_is_enabled "$name" || continue
            entries+=("$mcp_dir/client-config.json")
        done
    fi

    if (( ${#entries[@]} == 0 )) || ! command -v jq >/dev/null 2>&1; then
        rm -f "$out_file" 2>/dev/null || true
        return 0
    fi

    # Reduce each {"mcpServers": {...}} into a single combined object.
    # Later entries win on key collision (predictable, alphabetic order).
    mkdir -p "$(dirname "$out_file")"
    if ! jq -s 'reduce .[] as $i ({"mcpServers": {}}; .mcpServers += ($i.mcpServers // {}))' \
        "${entries[@]}" >"$out_file" 2>/dev/null
    then
        # Bad json in one of the entries — don't let it stop the agent.
        rm -f "$out_file" 2>/dev/null || true
        err "warning: failed to merge MCP client configs; agent will start without MCP"
    fi
}

# Run an agent (claude or opencode) in the current directory.
#
# Phase 18 dropped the tmux-detached-session model; the agent CLI is now the
# container's foreground process. /workspace is bind-mounted to $PWD and the
# shared agent home is bind-mounted from <install-root>/state/agent/home;
# the entrypoint also symlinks $PWD inside the container so `pwd` reflects
# the host path.
#
# -p / --print uses the same foreground path with HARNESS_PRINT_MODE=1 set
# (which makes opencode use `opencode run` and skips claude's first-run
# dialogs).
run_agent() {
    local tool="$1"; shift

    # Parse --yolo, --net, and -p/--print. --yolo and --net can appear
    # anywhere; -p / --print is preserved in pass_args (claude consumes it as
    # its own headless flag; opencode's entrypoint detects it and switches to
    # `opencode run`).
    local yolo=0
    local print_mode=0
    local net_open=0
    local pass_args=()
    for arg in "$@"; do
        case "$arg" in
            --yolo)
                yolo=1
                ;;
            --net)
                # Per-invocation firewall opt-out. Loud audit log on stderr
                # so the choice shows up in scrollback / shell logs even if
                # the user runs the agent unattended.
                net_open=1
                err "WARNING: --net disables the egress firewall for this $tool launch."
                err "         The container will have unrestricted outbound network."
                ;;
            -p|--print)
                print_mode=1
                pass_args+=("$arg")
                ;;
            *)
                pass_args+=("$arg")
                ;;
        esac
    done

    require_docker
    ensure_services_up
    ensure_dirs

    # Surface any drift detected by the prior invocation (file read + a
    # couple of git rev-parses; <10ms), then kick off a fresh background
    # check whose result the NEXT invocation will read.
    _show_update_banner_if_pending
    _check_for_update_async

    # Persistent agent firewall override: `harness net open agent` writes
    # an `agent` entry to .harness-net-overrides.json. Honor it here so
    # the launch picks up the disabled-firewall state without needing
    # --net per invocation. Either the per-launch flag or the persistent
    # override is enough.
    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        local agent_override
        agent_override=$(jq -r '.services.agent.firewall_disabled // false' "$net_overrides_path" 2>/dev/null || echo "false")
        if [[ "$agent_override" == "true" ]]; then
            net_open=1
        fi
    fi

    # Pre-launch: prompt user if any firewall is currently open. Skipped via
    # HARNESS_NET_CONFIRM=1 (set by tests). --net is part of the prompt
    # decision; we pass the flag in.
    warn_if_firewall_open "$net_open" "$tool" || exit 1

    local mount_path
    mount_path=$(realpath "$PWD")

    # Resolve unified image + shared home.
    local image agent_home
    image=$(agent_image)
    agent_home=$(agent_home_dir)
    mkdir -p "$agent_home"

    # Refresh the MCP side file before launch so the entrypoint sees the
    # current set of enabled MCPs. Done after mkdir so the dir exists.
    write_agent_mcp_config

    # Build image on demand if missing — different from the per-tool
    # behavior pre-13a where `harness start` was the only build path.
    # `harness <tool>` is the natural first command users try; auto-build
    # avoids the "no, you have to run start first" dance.
    if ! docker image inspect "$image" >/dev/null 2>&1; then
        echo "harness: building $image (one-time)..."
        compose --profile agent build agent || {
            err "agent image build failed; cannot launch $tool"
            exit 1
        }
    fi

    local network="${project_name}_harness-net"

    if (( print_mode )); then
        run_agent_print "$tool" "$yolo" "$net_open" "$mount_path" "$image" \
            "$agent_home" "$network" "${pass_args[@]}"
    else
        run_agent_interactive "$tool" "$yolo" "$net_open" "$mount_path" "$image" \
            "$agent_home" "$network" "${pass_args[@]}"
    fi
}

# Common -e flags shared between print and interactive launchers. Echoes
# one flag per line so the caller can splice them into a docker_args array.
agent_common_env() {
    local tool="$1"
    local yolo="$2"
    local net_open="${3:-0}"
    local mount_path="${4:-}"
    printf -- '-e\nHOST_UID=%s\n' "$(id -u)"
    printf -- '-e\nHOST_GID=%s\n' "$(id -g)"
    printf -- '-e\nHARNESS_YOLO=%s\n' "$yolo"
    printf -- '-e\nOLLAMA_AGENT_MODEL=%s\n' "$agent_model"
    # The entrypoint symlinks this path to /workspace so `pwd` inside the
    # container reflects the host path the user launched from.
    if [[ -n "$mount_path" ]]; then
        printf -- '-e\nHARNESS_HOST_CWD=%s\n' "$mount_path"
    fi
    if [[ "$net_open" == "1" ]]; then
        # Honored by firewall/init-firewall.sh — full opt-out. Setting it to
        # "0" explicitly when not opted-in is intentional: a stale value in
        # the environment can't accidentally re-enable the bypass.
        printf -- '-e\nHARNESS_FIREWALL_DISABLED=1\n'
    fi
    if [[ "$tool" == "claude" ]]; then
        printf -- '-e\nANTHROPIC_BASE_URL=http://ollama:11434\n'
        # AUTH_TOKEN (not API_KEY): claude-code's startup connectivity probe
        # to api.anthropic.com is gated to skip when AUTH_TOKEN is set; with
        # only API_KEY it hard-exits behind our default firewall.
        printf -- '-e\nANTHROPIC_AUTH_TOKEN=harness-dummy\n'
        printf -- '-e\nANTHROPIC_MODEL=%s\n' "$agent_model"
        printf -- '-e\nANTHROPIC_SMALL_FAST_MODEL=%s\n' "$agent_model"
    fi
}

# Build the env-flag array from agent_common_env's newline-delimited output.
collect_agent_env() {
    local tool="$1" yolo="$2" net_open="${3:-0}" mount_path="${4:-}"
    local -a out=()
    while IFS= read -r line; do
        out+=("$line")
    done < <(agent_common_env "$tool" "$yolo" "$net_open" "$mount_path")
    printf '%s\0' "${out[@]}"
}

run_agent_interactive() {
    local tool="$1" yolo="$2" net_open="$3" mount_path="$4" image="$5"
    local agent_home="$6" network="$7"
    shift 7
    local pass_args=("$@")

    local cname
    cname=$(agent_container_name "$tool" "$mount_path")

    # Already running for this dir+tool? Refuse — there's no reattach now,
    # so a duplicate would either compete for the TTY or just die in the
    # background. Stop the existing one first.
    if [[ -n "$(docker ps -q -f "name=^${cname}$" 2>/dev/null)" ]]; then
        err "$tool agent already running here ($cname)"
        err "stop it first with 'harness stop $cname' (or 'harness stop' for a picker)"
        exit 1
    fi

    # Clean up any stopped container with the same name (e.g. previous run
    # that exited but wasn't removed). Ignore errors.
    docker rm "$cname" >/dev/null 2>&1 || true

    # --user 0:0 overrides the image's USER harness directive so the
    # entrypoint can remap the harness uid/gid to the host caller before
    # gosu-dropping back to harness. Without this, the container runs as
    # harness uid 1000 directly and the remap block is bypassed (matching
    # the test-mode path used by full_pipeline_test.sh).
    #
    # --rm + -it: the agent CLI is the container's foreground process. The
    # user's terminal connects directly to its PTY; container exits when
    # the agent exits, and Docker removes it.
    local tty_flag="-it"
    [[ -t 0 ]] || tty_flag="-i"

    local docker_args=(
        run --rm "$tty_flag"
        --name "$cname"
        --user 0:0
        --network "$network"
        # The agent entrypoint runs init-firewall.sh as root before gosu-
        # dropping to harness; iptables/ipset need NET_ADMIN/NET_RAW.
        --cap-add NET_ADMIN
        --cap-add NET_RAW
    )

    local env_line
    while IFS= read -r -d '' env_line; do
        docker_args+=("$env_line")
    done < <(collect_agent_env "$tool" "$yolo" "$net_open" "$mount_path")

    # Normalize host bind-mount sources for Windows Docker Desktop.
    # On Linux/macOS these are passthrough; on Windows they're rewritten
    # to C:/Users/... form which Docker Desktop's WSL2 backend mounts
    # reliably (raw /tmp/... or /c/Users/... paths sometimes mount empty).
    local mp_host ah_host alp_host
    mp_host=$(harness_docker_path "$mount_path")
    ah_host=$(harness_docker_path "$agent_home")
    alp_host=$(harness_docker_path "$allowlist_path")

    docker_args+=(
        -v "$mp_host:/workspace"
        -v "$ah_host:/home/harness"
        # Universal firewall allowlist, read-only. The init script aborts the
        # container if this is missing.
        -v "$alp_host:/etc/harness/allowlist:ro"
        -w /workspace
        --label "harness.agent=true"
        --label "harness.project=$project_name"
        --label "harness.tool=$tool"
        --label "harness.mount=$mount_path"
        "$image"
        "$tool"
    )
    if (( ${#pass_args[@]} > 0 )); then
        docker_args+=("${pass_args[@]}")
    fi

    harness_docker_exec "${docker_args[@]}"
}

# Headless single-shot agent invocation. No tmux, no detach, no labels (so
# it doesn't appear in `harness list`). Container is auto-removed on exit.
# stdin handling: -it if running on a TTY, -i otherwise — claude needs the
# TTY for some output formats but pipe-based callers shouldn't get a TTY.
run_agent_print() {
    local tool="$1" yolo="$2" net_open="$3" mount_path="$4" image="$5"
    local agent_home="$6" network="$7"
    shift 7
    local pass_args=("$@")

    local tty_flag
    if [[ -t 0 ]]; then
        tty_flag="-it"
    else
        tty_flag="-i"
    fi

    local docker_args=(
        run --rm "$tty_flag"
        --user 0:0
        --network "$network"
        # See run_agent_interactive for the cap rationale.
        --cap-add NET_ADMIN
        --cap-add NET_RAW
    )

    local env_line
    while IFS= read -r -d '' env_line; do
        docker_args+=("$env_line")
    done < <(collect_agent_env "$tool" "$yolo" "$net_open" "$mount_path")

    # See run_agent_interactive for the harness_docker_path rationale.
    local mp_host ah_host alp_host
    mp_host=$(harness_docker_path "$mount_path")
    ah_host=$(harness_docker_path "$agent_home")
    alp_host=$(harness_docker_path "$allowlist_path")

    docker_args+=(
        -e "HARNESS_PRINT_MODE=1"
        -v "$mp_host:/workspace"
        -v "$ah_host:/home/harness"
        -v "$alp_host:/etc/harness/allowlist:ro"
        -w /workspace
        "$image"
        "$tool"
    )
    if (( ${#pass_args[@]} > 0 )); then
        docker_args+=("${pass_args[@]}")
    fi

    harness_docker_exec "${docker_args[@]}"
}

# Drop into an interactive bash shell inside the unified agent container.
# Uses the same shared home as `harness claude` / `harness opencode`, so any
# install (pipx, pip --user, etc.) the user does in here is visible to the
# agent commands later. Useful for installing skill-style tools (graphify),
# poking around, debugging.
cmd_shell() {
    require_docker
    ensure_dirs

    # Same banner + async refresh as run_agent; see _check_for_update_async.
    _show_update_banner_if_pending
    _check_for_update_async

    local image
    image=$(agent_image)
    if ! docker image inspect "$image" >/dev/null 2>&1; then
        echo "harness: building $image (one-time)..."
        compose --profile agent build agent || {
            err "agent image build failed; cannot launch shell"
            exit 1
        }
    fi

    local agent_home
    agent_home=$(agent_home_dir)
    mkdir -p "$agent_home"

    local mount_path
    mount_path=$(realpath "$PWD")

    local network="${project_name}_harness-net"
    if ! docker network inspect "$network" >/dev/null 2>&1; then
        # Network doesn't exist (services never started). Use the default
        # bridge — the shell doesn't need to talk to ollama or the proxy.
        network="bridge"
    fi

    local tty_flag="-it"
    [[ -t 0 ]] || tty_flag="-i"

    local mp_host ah_host alp_host
    mp_host=$(harness_docker_path "$mount_path")
    ah_host=$(harness_docker_path "$agent_home")
    alp_host=$(harness_docker_path "$allowlist_path")

    # Persistent agent firewall override (`harness net open agent`) lets the
    # shell launch with the firewall disabled too. Mirrors the run_agent
    # logic for claude/opencode launches.
    local fw_args=()
    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        local agent_override
        agent_override=$(jq -r '.services.agent.firewall_disabled // false' "$net_overrides_path" 2>/dev/null || echo "false")
        if [[ "$agent_override" == "true" ]]; then
            fw_args=(-e "HARNESS_FIREWALL_DISABLED=1")
        fi
    fi

    harness_docker_exec run --rm "$tty_flag" \
        --user 0:0 \
        --network "$network" \
        --cap-add NET_ADMIN \
        --cap-add NET_RAW \
        -e "HOST_UID=$(id -u)" \
        -e "HOST_GID=$(id -g)" \
        -e "HARNESS_HOST_CWD=$mount_path" \
        "${fw_args[@]}" \
        -v "$mp_host:/workspace" \
        -v "$ah_host:/home/harness" \
        -v "$alp_host:/etc/harness/allowlist:ro" \
        -w /workspace \
        "$image" \
        shell
}

cmd_list() {
    require_docker
    local rows
    rows=$(docker ps \
        --filter "label=harness.agent=true" \
        --format '{{.Names}}\t{{.Label "harness.tool"}}\t{{.Label "harness.mount"}}\t{{.RunningFor}}')
    if [[ -z "$rows" ]]; then
        echo "no harness agents running"
        return 0
    fi
    {
        printf 'NAME\tTOOL\tMOUNT\tAGE\n'
        printf '%s\n' "$rows"
    } | column -t -s $'\t'
}

# List all running harness agents, returns lines: <name>\t<tool>\t<mount>.
list_agents_raw() {
    docker ps \
        --filter "label=harness.agent=true" \
        --format '{{.Names}}\t{{.Label "harness.tool"}}\t{{.Label "harness.mount"}}'
}

# Render an interactive picker over the supplied newline-delimited list of
# agents (each line: name\ttool\tmount). Reads stdin for the selection.
# Echoes the chosen name on stdout.
pick_agent() {
    local rows="$1"
    if [[ ! -t 0 ]]; then
        err "ambiguous; provide a name explicitly"
        exit 1
    fi
    echo "running harness agents:" >&2
    local i=0
    local -a names=()
    while IFS=$'\t' read -r name tool mount; do
        i=$(( i + 1 ))
        names+=("$name")
        printf '  %d) %s  [%s]  %s\n' "$i" "$name" "$tool" "$mount" >&2
    done <<<"$rows"
    local choice
    read -rp "select [1-$i]: " choice </dev/tty
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > i )); then
        err "invalid selection"
        exit 1
    fi
    printf '%s\n' "${names[$((choice - 1))]}"
}

cmd_stop() {
    require_docker
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        local all
        all=$(list_agents_raw)
        if [[ -z "$all" ]]; then
            err "no harness agents running"
            exit 1
        fi
        local count
        count=$(printf '%s\n' "$all" | wc -l)
        if (( count == 1 )); then
            target=$(printf '%s' "$all" | cut -f1)
        else
            target=$(pick_agent "$all")
        fi
    fi

    docker stop "$target" >/dev/null
    docker rm "$target" >/dev/null 2>&1 || true
    echo "stopped: $target"
}

# --- mcp --------------------------------------------------------------------
#
# Long-running MCP services (Serena and friends) live in two parallel trees:
#
#   <repo>/mcp-registry/<name>/                # vetted definitions, source of truth
#   <install-root>/state/mcp/<name>/           # active copies; presence == enabled
#
# Enabling copies the registry entry into the active tree (preserving the
# upstream by-value, so the user can edit their copy without diverging the
# repo). Disabling removes everything except the optional `data/` dir,
# which holds per-MCP persistent state (indices, caches).

# Echo the registry entry directories that exist (one path per line). Names
# starting with `_` are reserved for fixtures (test entries) and excluded
# from the user-facing list view, but still resolvable by `enable`/`disable`
# for tests that target them by name.
list_registry_entries() {
    if [[ ! -d "$registry_dir" ]]; then
        return 0
    fi
    local d
    for d in "$registry_dir"/*/; do
        [[ -d "$d" ]] || continue
        printf '%s\n' "${d%/}"
    done
}

# Echo the active MCP entry directories that exist (one path per line).
list_active_entries() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 0
    fi
    local d
    for d in "$mcp_active_dir"/*/; do
        [[ -d "$d" ]] || continue
        printf '%s\n' "${d%/}"
    done
}

# Best-effort runtime status for a single MCP service: parses
# `docker compose ps` to find a container whose service name matches the
# active entry. Container-name matching is brittle by design — MCP composes
# don't have a uniform service name — so we report the first active service
# we find inside the snippet.
mcp_runtime_status() {
    local name="$1"
    local compose_file="$mcp_active_dir/$name/compose.yml"
    [[ -f "$compose_file" ]] || { printf -- '-'; return; }
    if ! docker info >/dev/null 2>&1; then
        printf -- 'docker-down'; return
    fi
    # Pull the first service name out of the compose snippet. Naive YAML —
    # the snippet shape is constrained (we control the registry) so this is
    # deliberately not a full parser.
    local svc
    svc=$(awk '
        /^services:/ { in_svc=1; next }
        in_svc && /^[A-Za-z]/ { in_svc=0 }
        in_svc && /^  [A-Za-z][A-Za-z0-9_-]*:/ {
            sub(/:.*$/, "")
            sub(/^[[:space:]]+/, "")
            print
            exit
        }
    ' "$compose_file")
    if [[ -z "$svc" ]]; then
        printf 'unknown'
        return
    fi
    local cid
    cid=$(compose ps -q "$svc" 2>/dev/null || true)
    if [[ -z "$cid" ]]; then
        printf 'stopped'
        return
    fi
    local running health
    running=$(docker inspect -f '{{.State.Running}}' "$cid" 2>/dev/null || echo "")
    health=$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || echo "")
    if [[ "$running" != "true" ]]; then
        printf 'stopped'
        return
    fi
    case "$health" in
        healthy)   printf 'running (healthy)' ;;
        unhealthy) printf 'running (unhealthy)' ;;
        starting)  printf 'starting' ;;
        none|"")   printf 'running' ;;
        *)         printf 'running (%s)' "$health" ;;
    esac
}

cmd_mcp_help() {
    cat <<'EOF'
harness mcp — manage long-running MCP services.

usage:
  harness mcp <subcommand> [args...]

subcommands:
  list [--available]            show installed entries with state. With
                                  --available also list registry entries
                                  not yet installed.
  install <name> [--force]      copy a registry entry into the active tree
                                  and mark it enabled.
  uninstall <name> [--force]    remove an installed entry; data/ is preserved
  enable <name>                 mark an installed MCP as auto-start.
                                  'harness start' brings it up next time.
  disable <name>                mark an installed MCP as do-not-auto-start.
                                  Container is left alone; use 'mcp down' to
                                  stop one immediately or 'mcp up' to start
                                  one without flipping its enable state.
  up <name>                     start an installed MCP container immediately
  down <name>                   stop an installed MCP container
  logs <name>                   follow logs for a single MCP
  status <name>                 per-MCP diagnostic

state diagram:
  available --install--> installed-enabled <-> installed-disabled
                                          \--uninstall--> available

The four canonical lifecycle verbs (install / uninstall / enable / disable)
are distinct: install/uninstall move between available and installed;
enable/disable flip the auto-start flag on an already-installed entry.

After install/uninstall/enable/disable, run 'harness start' (or
'harness upgrade') to materialize the change in the running compose stack.
'mcp up' / 'mcp down' bypass the start/down cycle and act on a single MCP.
EOF
}

cmd_mcp_list() {
    # Default: only show installed entries. With --available, also show
    # registry entries that haven't been installed yet (state: available).
    local show_available=0
    while (( $# > 0 )); do
        case "$1" in
            --available) show_available=1 ;;
            -*) err "unknown flag '$1'"; exit 1 ;;
            *) err "unexpected extra argument '$1'"; exit 1 ;;
        esac
        shift
    done

    local printed_header=0
    local seen_names=()

    # Walk the registry first (canonical order) and decorate with active state.
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        # Hide reserved test fixture names from user output.
        [[ "$name" =~ ^_ ]] && continue
        local state status
        if mcp_is_installed "$name"; then
            if mcp_is_enabled "$name"; then
                state="installed-enabled"
            else
                state="installed-disabled"
            fi
            status=$(mcp_runtime_status "$name")
        else
            state="available"
            status="-"
            (( show_available )) || { seen_names+=("$name"); continue; }
        fi
        if (( printed_header == 0 )); then
            printf '%-20s %-22s %s\n' "NAME" "STATE" "STATUS"
            printed_header=1
        fi
        printf '%-20s %-22s %s\n' "$name" "$state" "$status"
        seen_names+=("$name")
    done < <(list_registry_entries)

    # Surface anything in the active tree that doesn't have a registry entry
    # (locally-edited copies; install-custom removed in 13b).
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        [[ "$name" =~ ^_ ]] && continue
        local already=0 s
        for s in "${seen_names[@]}"; do
            if [[ "$s" == "$name" ]]; then already=1; break; fi
        done
        (( already )) && continue
        if (( printed_header == 0 )); then
            printf '%-20s %-22s %s\n' "NAME" "STATE" "STATUS"
            printed_header=1
        fi
        local state status
        if mcp_is_enabled "$name"; then
            state="installed-enabled"
        else
            state="installed-disabled"
        fi
        status=$(mcp_runtime_status "$name")
        printf '%-20s %-22s %s\n' "${name} (local)" "$state" "$status"
    done < <(list_active_entries)

    if (( printed_header == 0 )); then
        if (( show_available )); then
            echo "no MCP entries (registry: $registry_dir)"
        else
            echo "no MCPs installed; run 'harness mcp list --available' to see what's available"
        fi
    fi
}

# Names of available registry entries, comma-separated, for error messages.
mcp_registry_names_csv() {
    local out=""
    while IFS= read -r entry_dir; do
        [[ -n "$entry_dir" ]] || continue
        local name
        name=$(basename "$entry_dir")
        [[ "$name" =~ ^_ ]] && continue
        if [[ -z "$out" ]]; then
            out="$name"
        else
            out="$out, $name"
        fi
    done < <(list_registry_entries)
    printf '%s' "${out:-(none)}"
}

# Echo the service names declared in an MCP's compose snippet, one per line.
# Empty output means we couldn't enumerate (missing file or compose error).
#
# MCP compose snippets reference ${INSTALL_ROOT}, ${HARNESS_ALLOWLIST_PATH},
# and ${HARNESS_PROJECTS_ROOT} in volume specs. Without those exported,
# compose interpolates them to empty and rejects the file as invalid, so
# `config --services` returns empty and callers conclude "no services".
# Mirror the env contract the `compose` wrapper sets.
mcp_services_of() {
    local name="$1"
    local compose_file="$mcp_active_dir/$name/compose.yml"
    [[ -f "$compose_file" ]] || return 0
    local projects_root="${HARNESS_PROJECTS_ROOT:-$HOME}"
    INSTALL_ROOT="$install_root" \
        HARNESS_ALLOWLIST_PATH="$allowlist_path" \
        HARNESS_PROJECTS_ROOT="$projects_root" \
        docker compose -f "$compose_file" --profile mcp config --services 2>/dev/null || true
}

# install: registry -> active tree. Default state is enabled.
#
# B3-MANAGED: mcp-active-tree — <install-root>/state/mcp/<name>/. Created by this
# function from mcp-registry/<name>/. `harness upgrade` runs a per-MCP
# `directory_overwrite` registry action (gated on `condition: installed`)
# that refreshes compose.yml, client-config.json, README.md, etc., while
# preserving harness-meta.json (user enable state) and data/ (indexed
# state). See scripts/upgrade-manifest.json's `registry_actions` block.
cmd_mcp_install() {
    local force=0 name=""
    while (( $# > 0 )); do
        case "$1" in
            --force) force=1 ;;
            -*)      err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp install <name> [--force]"
        exit 1
    fi

    local src="$registry_dir/$name"
    if [[ ! -d "$src" ]]; then
        err "unknown MCP '$name'; available: $(mcp_registry_names_csv)"
        exit 1
    fi
    if [[ ! -f "$src/compose.yml" ]]; then
        err "registry entry '$name' is missing compose.yml"
        exit 1
    fi

    local dest="$mcp_active_dir/$name"
    # "Already installed" means compose.yml is present. After uninstall the
    # directory may still exist (data/ is preserved), so checking only for
    # the directory would refuse a clean re-install after an uninstall.
    if mcp_is_installed "$name" && (( ! force )); then
        err "$name is already installed (use --force to overwrite)"
        exit 1
    fi

    mkdir -p "$mcp_active_dir"
    if (( force )) && [[ -d "$dest" ]]; then
        # Wipe everything except data/ so persistent state survives a force-
        # reinstall. data is sacred.
        local f
        for f in "$dest"/*; do
            [[ -e "$f" ]] || continue
            if [[ "$(basename "$f")" == "data" ]]; then
                continue
            fi
            rm -rf "$f"
        done
    fi
    mkdir -p "$dest"
    local f
    for f in "$src"/* "$src"/.[!.]*; do
        [[ -e "$f" ]] || continue
        # The .template file is a registry-side default for harness-meta.json
        # that we materialize into the active tree below — copy as the real
        # filename rather than leaving the .template extension lying around.
        local base
        base=$(basename "$f")
        if [[ "$base" == "harness-meta.json.template" ]]; then
            cp -a "$f" "$dest/harness-meta.json"
            continue
        fi
        cp -a "$f" "$dest/"
    done
    mkdir -p "$dest/data"

    # If the registry meta declared a repo_clone_url, clone the upstream
    # repo into state/mcp/<name>/repo/ so the compose snippet can use a
    # local build context. Some upstreams (Serena) failed on Windows when
    # docker tried to fetch the build context directly from a git URL —
    # the WSL2 backend mis-parses the URL as a local path. Cloning here
    # is host-side, native git, no Docker URL parsing involved.
    #
    # Done BEFORE mcp_set_enabled because that helper has a jq-less
    # fallback that overwrites the meta with `{"enabled": true}` only —
    # which would drop repo_clone_url before we got to read it. By
    # reading the freshly-copied template meta first, we're immune.
    # harness_jq (host jq with Docker fallback) is used so the clone
    # block fires even when host jq is unavailable.
    local meta_file="$dest/harness-meta.json"
    if [[ -f "$meta_file" ]]; then
        local clone_url clone_ref
        clone_url=$(harness_jq -r '.repo_clone_url // empty' "$meta_file" 2>/dev/null || true)
        clone_ref=$(harness_jq -r '.repo_clone_ref // "main"' "$meta_file" 2>/dev/null || true)
        if [[ -n "$clone_url" ]]; then
            local clone_dir_local="$dest/repo"
            if [[ -d "$clone_dir_local/.git" ]]; then
                echo "[harness] $name: repo clone already present at $clone_dir_local; skipping clone"
            else
                # Clear any stale non-git directory so the clone target is empty.
                rm -rf "$clone_dir_local" 2>/dev/null || true
                echo "[harness] $name: cloning $clone_url ($clone_ref) to $clone_dir_local..."
                # Fatal on failure: the compose snippet build context points
                # at this path, so 'harness start' would fail later anyway —
                # better to fail loudly here than report a successful install.
                if ! git clone --depth=1 --branch "$clone_ref" "$clone_url" "$clone_dir_local"; then
                    err "$name: repo clone failed (target: $clone_dir_local)"
                    err "         clone URL: $clone_url ($clone_ref)"
                    err "         install aborted; retry with 'harness mcp install $name --force' once resolved"
                    exit 1
                fi
            fi
        fi
    fi

    # Always force enabled=true on a fresh install regardless of what (if
    # anything) the template said. allowed_domains and any other registry-side
    # defaults are preserved by the copy above. Done AFTER the clone block
    # so the jq-less fallback path in mcp_set_enabled can't drop
    # repo_clone_url before we read it.
    mcp_set_enabled "$name" "true"

    cat <<EOF
installed: $name (from $src)
state: installed-enabled
data: $dest/data
next:
  run 'harness start' (or 'harness restart' if the stack is already up) to bring up the service.
  agents launched after that will see this MCP in their config.
EOF

    # If the MCP's harness-meta.json declared allowed_domains, surface them
    # as a recommendation. We DO NOT auto-add — the user should make the
    # network-policy decision deliberately. Empty arrays produce no output.
    local installed_meta="$dest/harness-meta.json"
    if [[ -f "$installed_meta" ]] && command -v jq >/dev/null 2>&1; then
        local domains
        domains=$(jq -r '(.allowed_domains // []) | .[]' "$installed_meta" 2>/dev/null || true)
        if [[ -n "$domains" ]]; then
            echo
            echo "this MCP recommends allowlisting the following domains for outbound traffic:"
            local d
            while IFS= read -r d; do
                [[ -z "$d" ]] && continue
                echo "  $d"
            done <<<"$domains"
            echo
            echo "to add them, run:"
            while IFS= read -r d; do
                [[ -z "$d" ]] && continue
                echo "  harness net allow $d"
            done <<<"$domains"
        fi
    fi
}

# uninstall: stop containers, remove active tree (preserve data/).
cmd_mcp_uninstall() {
    local force=0 name=""
    while (( $# > 0 )); do
        case "$1" in
            --force) force=1 ;;
            -*)      err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp uninstall <name> [--force]"
        exit 1
    fi

    local dest="$mcp_active_dir/$name"
    if [[ ! -d "$dest" ]]; then
        err "$name is not installed"
        exit 1
    fi

    if (( ! force )); then
        local ans
        printf 'this will stop and remove the active config for %s. ' "$name" >&2
        printf 'data dir at %s/data will be preserved. continue? [y/N]: ' "$dest" >&2
        if [[ -t 0 ]]; then
            read -r ans </dev/tty
        else
            err "non-interactive shell; pass --force to confirm"
            exit 1
        fi
        case "${ans:-}" in
            y|Y|yes|YES) ;;
            *) echo "aborted." >&2; exit 0 ;;
        esac
    fi

    # Stop and remove the MCP's containers if running. Enumerate services
    # via `compose config --services` (--profile mcp required to see them)
    # and `compose rm -sf` each one through the full project compose so we
    # don't disturb the core services or other MCPs.
    if [[ -f "$dest/compose.yml" ]] && docker info >/dev/null 2>&1; then
        local svc
        while IFS= read -r svc; do
            [[ -z "$svc" ]] && continue
            compose --profile mcp rm -sf "$svc" 2>/dev/null || true
        done < <(mcp_services_of "$name")
    fi

    local f
    for f in "$dest"/* "$dest"/.[!.]*; do
        [[ -e "$f" ]] || continue
        if [[ "$(basename "$f")" == "data" ]]; then
            continue
        fi
        rm -rf "$f"
    done
    if [[ ! -d "$dest/data" ]]; then
        rmdir "$dest" 2>/dev/null || true
    fi

    echo "uninstalled: $name"
    if [[ -d "$dest/data" ]]; then
        echo "data preserved at: $dest/data"
    fi
}

# enable: mark installed MCP as auto-start. Pure state-flag flip.
cmd_mcp_enable() {
    local name=""
    while (( $# > 0 )); do
        case "$1" in
            -*) err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp enable <name>"
        exit 1
    fi

    if ! mcp_is_installed "$name"; then
        if [[ -d "$registry_dir/$name" ]]; then
            err "$name is in the registry but not installed; use 'harness mcp install $name' first"
        else
            err "unknown MCP '$name'; available: $(mcp_registry_names_csv)"
        fi
        exit 1
    fi

    mcp_set_enabled "$name" "true"
    echo "enabled: $name"
    echo "next: 'harness start' (or 'harness upgrade') to bring it up."
}

# disable: mark installed MCP as do-not-auto-start. Pure state-flag flip.
cmd_mcp_disable() {
    local name=""
    while (( $# > 0 )); do
        case "$1" in
            -*) err "unknown flag '$1'"; exit 1 ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    err "unexpected extra argument '$1'"
                    exit 1
                fi
                ;;
        esac
        shift
    done
    if [[ -z "$name" ]]; then
        err "usage: harness mcp disable <name>"
        exit 1
    fi

    if ! mcp_is_installed "$name"; then
        err "$name is not installed"
        exit 1
    fi
    mcp_set_enabled "$name" "false"
    echo "disabled: $name (still installed; data + config preserved)"
    echo "next: 'harness mcp down $name' to stop a running container, or"
    echo "      'harness start' to apply the change to the running stack."
}

# up: start an installed MCP's containers regardless of enabled flag.
cmd_mcp_up() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        err "usage: harness mcp up <name>"
        exit 1
    fi
    if ! mcp_is_installed "$name"; then
        err "$name is not installed"
        exit 1
    fi
    require_docker

    local svc_list=()
    local svc
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        svc_list+=("$svc")
    done < <(mcp_services_of "$name")
    if (( ${#svc_list[@]} == 0 )); then
        err "could not enumerate services in $mcp_active_dir/$name/compose.yml"
        exit 1
    fi

    # Force-add this MCP's compose file to the argv even if it's disabled —
    # `compose` (the wrapper) only adds enabled MCPs through mcp_compose_files.
    write_runtime_override
    local args=(
        compose
        --project-name "$project_name"
        -f "$clone_dir/docker-compose.yml"
    )
    if [[ -f "$env_file" ]]; then args+=(--env-file "$env_file"); fi
    if [[ -f "$runtime_override" ]]; then args+=(-f "$runtime_override"); fi
    # Other enabled MCPs (so their networks/volumes resolve consistently).
    local mcp_arg
    while IFS= read -r mcp_arg; do
        [[ -n "$mcp_arg" ]] && args+=("$mcp_arg")
    done < <(mcp_compose_files)
    # Force this MCP in, even if disabled.
    if ! mcp_is_enabled "$name"; then
        args+=(-f "$mcp_active_dir/$name/compose.yml")
    fi
    args+=(--profile mcp up -d)
    args+=("${svc_list[@]}")
    local projects_root="${HARNESS_PROJECTS_ROOT:-$HOME}"
    INSTALL_ROOT="$install_root" \
        HARNESS_ALLOWLIST_PATH="$allowlist_path" \
        HARNESS_PROJECTS_ROOT="$projects_root" \
        docker "${args[@]}"
    echo "up: $name"
}

