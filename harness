#!/usr/bin/env bash
#
# harness — management entrypoint for the harness runtime.
#
# Layout assumed at runtime (the install root IS the git clone — they are
# the same directory):
#
#   <install-root>/                       # also the git clone
#     .git/                                # managed by 'harness update'
#     harness                              # this file (tracked)
#     docker-compose.yml                   # tracked
#     mcp-registry/                        # vetted MCP definitions (tracked)
#     ...
#     .env                                 # gitignored — user config
#     .harness-allowlist                   # gitignored — egress allowlist
#     state/                               # gitignored — runtime state
#       output/                            # bind-mounted into the proxy
#       agent/home/                        # shared agent /home/harness
#                                            (claude, opencode, shell)
#       mcp/<name>/                        # active MCP services
#       ollama-data/                       # ollama's blob store
#
# This script is symlinked into ~/.local/bin/harness by install.sh; we use
# realpath on $0 to resolve the script's true location independent of how
# it was invoked. The script's parent directory is both the clone and the
# install root.

set -euo pipefail

# --- self-locate ------------------------------------------------------------
#
# In production we resolve $0 through any wrapper or symlink
# (~/.local/bin/harness -> <install-root>/harness) to find the install root,
# which is also the git clone. The wrapper script installed by harness-
# install.sh exec's into this script, so $0 here resolves to the real
# install-root path. Tests can override via HARNESS_INSTALL_ROOT — useful
# when the test layout uses symlinks that would otherwise collapse dirname
# into the real repo path.
#
# We use a portable resolver here rather than depending on `realpath` so
# the script also works on Windows Git Bash and on minimal images where
# realpath isn't installed. The full equivalent lives in
# scripts/lib/platform.sh:harness_realpath; the helper sourced below.

_self_path() {
    if command -v realpath >/dev/null 2>&1; then
        realpath "$1"
    elif command -v readlink >/dev/null 2>&1 && readlink -f "$1" >/dev/null 2>&1; then
        readlink -f "$1"
    else
        cd "$(dirname "$1")" && echo "$(pwd -P)/$(basename "$1")"
    fi
}

real_self=$(_self_path "$0")
# clone_dir is where the code lives (this script + docker-compose.yml + scripts/).
# install_root is where the user config (.env, .harness-allowlist) and runtime
# state (state/) live. In production these are the same directory: install.sh
# clones the repo and that clone IS the install root. Tests can override
# HARNESS_INSTALL_ROOT to point at a tmpdir while keeping clone_dir resolved
# to the real repo (via the script's realpath); without HARNESS_INSTALL_ROOT,
# install_root falls back to clone_dir and the layout is single-folder.
clone_dir=$(dirname "$real_self")

# Source the cross-platform helper library so the rest of the script can
# call harness_detect_os, harness_require_docker, etc. The library is
# installed alongside this script in scripts/lib/platform.sh.
if [[ -f "$clone_dir/scripts/lib/platform.sh" ]]; then
    # shellcheck disable=SC1091
    source "$clone_dir/scripts/lib/platform.sh"
fi
install_root="${HARNESS_INSTALL_ROOT:-$clone_dir}"
state_root="$install_root/state"
env_file="$install_root/.env"
runtime_override="$state_root/.harness-runtime.yml"

# Universal egress firewall allowlist. Bind-mounted into every harness
# container at /etc/harness/allowlist. install.sh seeds this from
# .harness-allowlist.example on a fresh install. Tests can override by
# setting HARNESS_ALLOWLIST_PATH.
allowlist_path="${HARNESS_ALLOWLIST_PATH:-$install_root/.harness-allowlist}"

# B3-MANAGED: net-overrides — JSON file holding per-service firewall opt-out
# state. Written by `harness net open/close <service>`; read by
# write_runtime_override to inject HARNESS_FIREWALL_DISABLED=1 env vars onto
# the matching services in the generated compose override. Tests can
# substitute their own path via HARNESS_NET_OVERRIDES_PATH.
net_overrides_path="${HARNESS_NET_OVERRIDES_PATH:-$install_root/.harness-net-overrides.json}"

# Tests can substitute their own registry by overriding HARNESS_REGISTRY_DIR.
# Defaults to the repo's bundled mcp-registry/ folder so users see the
# vetted set out-of-the-box.
registry_dir="${HARNESS_REGISTRY_DIR:-$clone_dir/mcp-registry}"
mcp_active_dir="$state_root/mcp"

# Project name is fixed by spec but overridable for tests so harness_test.sh
# can run without colliding with a real harness instance on the same daemon.
project_name="${HARNESS_PROJECT_NAME:-harness}"

# --- env loading ------------------------------------------------------------
#
# Source .env into this shell so we can read PUBLISH_OLLAMA_PORT,
# OLLAMA_AGENT_MODEL etc. for our own logic. docker compose gets the file
# separately via --env-file.

if [[ -f "$env_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$env_file"
    set +a
fi

agent_model="${OLLAMA_AGENT_MODEL:-harness}"

# --- net helpers (lazy load) ------------------------------------------------
#
# scripts/lib/net_helpers.sh is shared between the harness script and tests.
# We source it on first use so the no-op startup cost on commands that don't
# touch the network (e.g. `harness logs`) stays close to zero.

netlib_loaded=0
load_net_helpers() {
    if (( netlib_loaded )); then return 0; fi
    local lib="$clone_dir/scripts/lib/net_helpers.sh"
    if [[ ! -f "$lib" ]]; then
        err "internal: $lib is missing — broken install"
        exit 1
    fi
    # NETLIB_* must persist after `source` returns: the lib's functions read
    # them at call time, not at source time. The `VAR=val source` prefix
    # syntax only scopes the assignment to the source builtin itself.
    NETLIB_ALLOWLIST="$allowlist_path"
    NETLIB_OVERRIDES="$net_overrides_path"
    # shellcheck disable=SC1090
    source "$lib"
    netlib_loaded=1
}

# --- helpers ----------------------------------------------------------------

# Print to stderr in the standard `harness:` format.
err() {
    echo "harness: $*" >&2
}

# harness_jq — wrapper that uses host jq if available, else falls back to
# the proxy container's jq via `docker run`. Same args/stdin/stdout/exit
# semantics as native jq.
#
# Why: the harness script's upgrade flow uses jq to parse the manifest,
# but jq is a host dependency users frequently don't have. Forcing them to
# install it via platform-specific package managers is poor UX. The proxy
# image (harness-proxy:latest) ships jq for its own firewall scripts;
# using `docker run --rm -i harness-proxy:latest jq` works transparently
# without adding host dependencies.
#
# Caveats:
# - Per-call overhead is ~200ms (Docker container start). harness upgrade
#   makes a handful of jq calls; total added latency ~1-2s. Acceptable.
# - First fallback in a fresh install (no proxy image yet) builds the
#   image inline. We tell the user this is happening so they don't think
#   the script froze. Build is one-time; subsequent calls are fast.
# - If Docker isn't running, both paths fail. Clear error.
harness_jq() {
    if command -v jq >/dev/null 2>&1; then
        jq "$@"
        return $?
    fi

    # Host jq missing. Fall back to the proxy container.
    if ! command -v docker >/dev/null 2>&1; then
        echo "harness: jq is required but not installed on the host," >&2
        echo "harness: and Docker isn't installed either as a fallback." >&2
        echo "harness: install Docker (which harness already requires) or" >&2
        echo "harness: install jq via your package manager." >&2
        return 1
    fi

    if ! docker info >/dev/null 2>&1; then
        echo "harness: jq is required but not installed on the host," >&2
        echo "harness: and the Docker daemon isn't running for the fallback." >&2
        echo "harness: start Docker Desktop / the docker daemon and retry." >&2
        return 1
    fi

    if ! docker image inspect harness-proxy:latest >/dev/null 2>&1; then
        echo "harness: jq isn't installed on the host. Falling back to the" >&2
        echo "harness: proxy container's jq, but its image isn't built yet." >&2
        echo "harness: building harness-proxy:latest now (one-time, ~2-5 minutes)..." >&2

        if ! (cd "$install_root" && compose build proxy >&2); then
            echo "harness: proxy image build failed; cannot fall back to" >&2
            echo "harness: container jq. Install jq directly via your package" >&2
            echo "harness: manager (apt/dnf/brew/pacman) and retry." >&2
            return 1
        fi
        echo "harness: proxy image built; resuming." >&2
    fi

    # The container can't see host filesystem paths. If the last argument is
    # a host file that exists, redirect it as stdin instead of passing it as
    # a positional arg. This handles `jq '...' file.json` callers (manifest
    # parsing in cmd_upgrade, net overrides file in netlib_overrides_*).
    local args=("$@")
    local n=${#args[@]}
    if (( n > 0 )) && [[ -f "${args[n-1]}" ]]; then
        local file="${args[n-1]}"
        unset 'args[n-1]'
        docker run --rm -i --entrypoint jq harness-proxy:latest "${args[@]}" <"$file"
    else
        docker run --rm -i --entrypoint jq harness-proxy:latest "$@"
    fi
}

# --- update-available banner ----------------------------------------------
#
# Cheap, non-blocking "is harness behind origin/main?" check. Two halves:
#
# - _check_for_update_async fires `git ls-remote` in a backgrounded subshell
#   that writes the remote main HEAD into state/.harness-update-check. The
#   parent does not wait — agent startup latency is unaffected.
#
# - _show_update_banner_if_pending reads that cache file (populated by the
#   PRIOR invocation), compares to local HEAD, and prints a one-line banner
#   to stderr if they differ. This gives "check on every invocation"
#   semantics with zero blocking cost: drift detected by run N is surfaced
#   at the start of run N+1.
#
# Skipped entirely when HARNESS_SKIP_UPDATE_CHECK=1, when not in a git
# checkout, or when not on main (working from a feature branch shouldn't
# nag the user about origin/main).
_check_for_update_async() {
    [[ "${HARNESS_SKIP_UPDATE_CHECK:-0}" == "1" ]] && return 0
    [[ -d "${install_root}/.git" ]] || return 0
    local branch
    branch=$(git -C "$install_root" symbolic-ref --short HEAD 2>/dev/null) || return 0
    [[ "$branch" == "main" ]] || return 0
    # Fire and forget. Result lands in the cache file for the NEXT invocation.
    (
        local remote_head
        remote_head=$(timeout 5 git -C "$install_root" ls-remote --heads origin main 2>/dev/null | awk '{print $1}')
        if [[ -n "$remote_head" ]]; then
            mkdir -p "${install_root}/state" 2>/dev/null
            printf '%s\n' "$remote_head" >"${install_root}/state/.harness-update-check" 2>/dev/null
        fi
    ) &
    # Detach so SIGHUP from the parent doesn't kill it before the write.
    disown 2>/dev/null || true
    return 0
}

_show_update_banner_if_pending() {
    [[ "${HARNESS_SKIP_UPDATE_CHECK:-0}" == "1" ]] && return 0
    local cache="${install_root}/state/.harness-update-check"
    [[ -f "$cache" ]] || return 0
    [[ -d "${install_root}/.git" ]] || return 0
    local branch
    branch=$(git -C "$install_root" symbolic-ref --short HEAD 2>/dev/null) || return 0
    [[ "$branch" == "main" ]] || return 0
    local remote_head local_head
    remote_head=$(cat "$cache" 2>/dev/null | tr -d '\r\n[:space:]')
    local_head=$(git -C "$install_root" rev-parse HEAD 2>/dev/null)
    [[ -n "$remote_head" && -n "$local_head" ]] || return 0
    [[ "$remote_head" == "$local_head" ]] && return 0
    echo "[harness] update available; run 'harness upgrade' to update" >&2
}

# Synchronous variant of the above for `harness check-updates`. Performs
# the ls-remote in the foreground, populates the cache file, and prints
# either "up to date" or the same banner. Useful for CI, and for users who
# want to force a fresh check without launching an agent.
cmd_check_updates() {
    if [[ ! -d "${install_root}/.git" ]]; then
        err "not a git checkout (no $install_root/.git); update check unavailable"
        return 1
    fi
    local branch
    branch=$(git -C "$install_root" symbolic-ref --short HEAD 2>/dev/null) || branch=""
    if [[ "$branch" != "main" ]]; then
        echo "[harness] not on main (current: ${branch:-detached}); skipping update check"
        return 0
    fi
    local remote_head
    remote_head=$(timeout 10 git -C "$install_root" ls-remote --heads origin main 2>/dev/null | awk '{print $1}')
    if [[ -z "$remote_head" ]]; then
        err "could not reach origin/main (offline, or no remote configured)"
        return 1
    fi
    mkdir -p "${install_root}/state" 2>/dev/null
    printf '%s\n' "$remote_head" >"${install_root}/state/.harness-update-check" 2>/dev/null
    local local_head
    local_head=$(git -C "$install_root" rev-parse HEAD 2>/dev/null)
    if [[ "$remote_head" == "$local_head" ]]; then
        echo "[harness] up to date with origin/main ($(echo "$local_head" | cut -c1-7))"
        return 0
    fi
    echo "[harness] update available; run 'harness upgrade' to update"
    return 0
}

# Ensure the docker daemon is reachable; auto-start Docker Desktop on
# Windows / macOS if we can. Hard exit with a helpful message otherwise.
# Delegates to platform.sh:harness_require_docker when the library is
# available; falls back to the original probe-only check if not.
require_docker() {
    if declare -f harness_require_docker >/dev/null 2>&1; then
        harness_require_docker
        return 0
    fi
    if ! docker info >/dev/null 2>&1; then
        err "docker daemon is not reachable; is it running?"
        exit 1
    fi
}

# Validate runtime configuration (.env presence, required vars) before
# bringing services up. Lightweight subset of `harness preflight` so users
# get a clear error before docker compose churns through a build/up cycle
# that's destined to fail in the proxy container.
require_runtime_config() {
    if [[ ! -f "$env_file" ]]; then
        err "missing $env_file"
        err "run 'harness preflight' for details, or recreate from .env.example:"
        err "  cp $clone_dir/.env.example $env_file"
        exit 1
    fi

    local missing=()
    local v
    for v in PROXY_API_URL PROXY_API_KEY PROXY_API_MODEL; do
        local val="${!v:-}"
        if [[ -z "$val" ]]; then
            missing+=("$v")
        fi
    done
    if (( ${#missing[@]} > 0 )); then
        err "required value(s) empty in $env_file: ${missing[*]}"
        err "edit $env_file and set them, then re-run. See 'harness preflight' for details."
        exit 1
    fi

    if [[ ! -f "$allowlist_path" ]]; then
        err "missing firewall allowlist at $allowlist_path"
        err "seed it from .harness-allowlist.example, or run 'harness preflight'"
        exit 1
    fi
}

# Create the install-root persistent directories if they don't exist.
ensure_dirs() {
    mkdir -p \
        "$state_root/output" \
        "$state_root/agent/home" \
        "$state_root/ollama-data" \
        "$mcp_active_dir"
}

# Echo the -f arguments for every installed-and-enabled MCP compose snippet,
# one flag/value pair per line. Disabled MCPs are skipped (their dir stays
# but they don't get spliced into the compose stack).
mcp_compose_files() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 0
    fi
    local mcp_dir name
    for mcp_dir in "$mcp_active_dir"/*/; do
        [[ -f "$mcp_dir/compose.yml" ]] || continue
        name=$(basename "$mcp_dir")
        mcp_is_enabled "$name" || continue
        printf '%s\n' "-f" "$mcp_dir/compose.yml"
    done
}

# True if any installed MCP is currently enabled. Drives `harness start`'s
# decision to add `--profile mcp` to the up command.
any_mcp_active() {
    if [[ ! -d "$mcp_active_dir" ]]; then
        return 1
    fi
    local mcp_dir name
    for mcp_dir in "$mcp_active_dir"/*/; do
        [[ -f "$mcp_dir/compose.yml" ]] || continue
        name=$(basename "$mcp_dir")
        mcp_is_enabled "$name" && return 0
    done
    return 1
}

# --- mcp state helpers ------------------------------------------------------
#
# State is tracked in <mcp_active_dir>/<name>/harness-meta.json:
#
#   {"enabled": true|false}
#
# Missing meta file == enabled (legacy default; pre-Phase-7a installs had
# no meta and were always treated as enabled). Writes are atomic via a
# temp file + mv so a crashed write can't leave half-parsed JSON.

mcp_meta_file() {
    printf '%s/%s/harness-meta.json' "$mcp_active_dir" "$1"
}

# True iff an MCP is installed (i.e., has compose.yml in the active tree).
mcp_is_installed() {
    [[ -f "$mcp_active_dir/$1/compose.yml" ]]
}

# True iff an MCP is enabled. Returns 0 when meta file is missing so legacy
# installs continue to behave as enabled.
mcp_is_enabled() {
    local name="$1"
    local meta
    meta=$(mcp_meta_file "$name")
    if [[ ! -f "$meta" ]]; then
        return 0
    fi
    if command -v jq >/dev/null 2>&1; then
        # NOTE: jq's `//` operator treats `false` as a missing value, so
        # `.enabled // true` returns true even when enabled is explicitly
        # false. Use the explicit null-check instead.
        local v
        v=$(jq -r 'if .enabled == null then "true" else (.enabled | tostring) end' "$meta" 2>/dev/null || echo "true")
        [[ "$v" == "true" ]]
    else
        # No jq — naive grep. Treat anything but an explicit false as enabled.
        ! grep -qE '"enabled"[[:space:]]*:[[:space:]]*false' "$meta"
    fi
}

# Set meta.enabled to "true" or "false" atomically. Creates the file if it
# doesn't already exist.
mcp_set_enabled() {
    local name="$1" value="$2"
    local meta
    meta=$(mcp_meta_file "$name")
    mkdir -p "$(dirname "$meta")"
    if command -v jq >/dev/null 2>&1 && [[ -f "$meta" ]]; then
        local tmp="${meta}.tmp.$$"
        if jq ".enabled = $value" "$meta" >"$tmp" 2>/dev/null; then
            mv "$tmp" "$meta"
            return 0
        fi
        rm -f "$tmp" 2>/dev/null || true
    fi
    # Fresh write or jq-less fallback.
    printf '{"enabled": %s}\n' "$value" >"$meta"
}

# Generate the runtime override file in-place. The file is rewritten on
# every invocation that runs `compose`, so toggling state via
# `harness net open/close` or PUBLISH_OLLAMA_PORT propagates immediately on
# the next `harness start` / `harness restart`.
#
# Two pieces of state can land in the override:
#   1. PUBLISH_OLLAMA_PORT — publishes ollama on a host port if non-empty.
#   2. .harness-net-overrides.json — per-service `firewall_disabled: true`
#      becomes an environment block on that service that the firewall
#      init-script honors as an opt-out.
#
# When both pieces are empty the override file is removed entirely (compose
# is invoked without the -f flag). This keeps `harness start` exactly as it
# was for installs that don't use either feature.
write_runtime_override() {
    # Build the body in a temp variable, write only if non-empty.
    local body=""

    # 1. PUBLISH_OLLAMA_PORT.
    if [[ -n "${PUBLISH_OLLAMA_PORT:-}" ]]; then
        body+="  ollama:"$'\n'
        body+="    ports:"$'\n'
        body+="      - \"${PUBLISH_OLLAMA_PORT}:11434\""$'\n'
    fi

    # 2. Per-service firewall opt-out.
    #
    # Every service that has firewall_disabled=true in the JSON gets a
    # `HARNESS_FIREWALL_DISABLED=1` env entry. The firewall init script
    # short-circuits on that variable. We never replace the service's
    # entrypoint or remove its cap_add — option A from the design docs.
    #
    # The 'agent' pseudo-service is filtered out here: agent containers
    # are not in the compose model (they're started by direct docker run
    # from cmd_claude/cmd_opencode/cmd_shell). The agent launch path
    # reads the override file directly. Emitting a services.agent block
    # would either create a phantom compose service or trigger validation
    # warnings depending on the compose version.
    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        local svc
        while IFS= read -r svc; do
            svc=${svc%$'\r'}
            [[ -z "$svc" ]] && continue
            [[ "$svc" == "agent" ]] && continue
            body+="  ${svc}:"$'\n'
            body+="    environment:"$'\n'
            body+="      HARNESS_FIREWALL_DISABLED: \"1\""$'\n'
        done < <(jq -r '
            (.services // {})
            | to_entries[]
            | select(.value.firewall_disabled == true)
            | .key
        ' "$net_overrides_path" 2>/dev/null || true)
    fi

    if [[ -z "$body" ]]; then
        rm -f "$runtime_override"
        return 0
    fi
    mkdir -p "$(dirname "$runtime_override")"
    {
        echo "# Generated by harness; do not edit. Regenerated on every invocation."
        echo "services:"
        printf '%s' "$body"
    } >"$runtime_override"
}

# Wrap docker compose with all the args we always pass. INSTALL_ROOT,
# HARNESS_ALLOWLIST_PATH, and HARNESS_PROJECTS_ROOT are exported so MCP
# compose snippets can reference them via plain ${VAR} (no defaults). The
# fallback for HARNESS_PROJECTS_ROOT is computed here in bash rather than
# in YAML because docker compose's interpolation parser doesn't reliably
# resolve nested defaults like ${A:-${B}} — keeping compose snippets to
# single-level ${VAR} references avoids that whole class of bug.
compose() {
    write_runtime_override
    local args=(
        compose
        --project-name "$project_name"
        -f "$clone_dir/docker-compose.yml"
    )
    if [[ -f "$env_file" ]]; then
        args+=(--env-file "$env_file")
    fi
    if [[ -f "$runtime_override" ]]; then
        args+=(-f "$runtime_override")
    fi

    # Splice in any active MCP compose snippets. Each one assumes the
    # external network harness_harness-net is reachable; it is iff this
    # project's compose has already been brought up (see cmd_start).
    local mcp_arg
    while IFS= read -r mcp_arg; do
        [[ -n "$mcp_arg" ]] && args+=("$mcp_arg")
    done < <(mcp_compose_files)

    # HARNESS_PROJECTS_ROOT may be set in .env (which compose reads via
    # --env-file) or absent. If absent, fall back to the host's $HOME so
    # the serena bind-mount always has a non-empty source.
    local projects_root="${HARNESS_PROJECTS_ROOT:-$HOME}"

    INSTALL_ROOT="$install_root" \
        HARNESS_ALLOWLIST_PATH="$allowlist_path" \
        HARNESS_PROJECTS_ROOT="$projects_root" \
        docker "${args[@]}" "$@"
}

# Best-effort check: are ollama and proxy both running for this project?
services_up() {
    local ollama_id proxy_id
    ollama_id=$(compose ps -q ollama 2>/dev/null || true)
    proxy_id=$(compose ps -q proxy 2>/dev/null || true)
    [[ -n "$ollama_id" && -n "$proxy_id" ]] || return 1
    docker inspect -f '{{.State.Running}}' "$ollama_id" 2>/dev/null | grep -q '^true$' || return 1
    docker inspect -f '{{.State.Running}}' "$proxy_id"  2>/dev/null | grep -q '^true$' || return 1
    return 0
}

# Bring services up if they aren't already. Used before launching agents.
ensure_services_up() {
    if ! services_up; then
        echo "harness: services not running; starting..."
        cmd_start
    fi
}

# Deterministic short suffix for an agent container name. Two simultaneous
# agents in the same dir for the same tool would collide, so we hash the
# absolute mount path together with the tool name and take the first 8 chars.
agent_container_name() {
    local tool="$1"
    local mount="$2"
    local hash
    hash=$(printf '%s' "$tool:$mount" | sha256sum | cut -c1-8)
    printf 'harness-%s-%s' "$tool" "$hash"
}

# Pre-launch check: if the firewall is currently disabled (either via --net
# for this invocation or via persistent `harness net open <service>` state),
# print a loud warning and prompt the user before continuing.
#
# Args: <agent_net_open_int> <tool>
# Returns: 0 to proceed, 1 to abort.
#
# HARNESS_NET_CONFIRM=1 short-circuits the prompt (used by tests and by
# users who've decided they don't want to be re-prompted every launch).
warn_if_firewall_open() {
    local agent_net_open="${1:-0}"
    local tool="${2:-agent}"

    local warn_messages=()
    if (( agent_net_open )); then
        warn_messages+=("This agent is being launched with --net (firewall DISABLED for this invocation).")
    fi
    if [[ -f "$net_overrides_path" ]] && command -v jq >/dev/null 2>&1; then
        local opened
        opened=$(jq -r '
            (.services // {})
            | to_entries[]?
            | select(.value.firewall_disabled == true)
            | .key
        ' "$net_overrides_path" 2>/dev/null || true)
        if [[ -n "$opened" ]]; then
            local list
            list=$(printf '%s' "$opened" | tr '\n' ' ' | sed 's/ *$//')
            warn_messages+=("These services are running with firewall DISABLED: $list")
        fi
    fi

    if (( ${#warn_messages[@]} == 0 )); then
        return 0
    fi

    echo >&2
    echo "WARNING: NETWORK FIREWALL IS DISABLED" >&2
    local msg
    for msg in "${warn_messages[@]}"; do
        echo "  ! $msg" >&2
    done
    echo >&2
    echo "Network egress from these contexts is NOT filtered by the harness allowlist." >&2
    echo >&2

    if [[ "${HARNESS_NET_CONFIRM:-0}" == "1" ]]; then
        echo "  (auto-confirmed via HARNESS_NET_CONFIRM=1)" >&2
        return 0
    fi

    if [[ ! -e /dev/tty ]]; then
        err "non-interactive shell without /dev/tty; refusing to launch $tool"
        err "set HARNESS_NET_CONFIRM=1 to skip this prompt in automation"
        return 1
    fi

    local ans
    printf 'Continue starting %s? [y/N]: ' "$tool" >&2
    if ! IFS= read -r ans </dev/tty; then
        err "no input received; aborting"
        return 1
    fi
    case "${ans:-}" in
        y|Y|yes|YES) return 0 ;;
        *) err "aborted by user"; return 1 ;;
    esac
}

# --- subcommands ------------------------------------------------------------

# Probe the upstream API to verify the key is valid and unlocked. Returns:
#   0 — key works, proceed
#   1 — key is locked or invalid, do not proceed
#   2 — upstream unhealthy (timeout, 5xx) — warn but allow proceed
# When the key is locked, prints the unlock URL prominently to the user.
#
# Why a host-side probe instead of letting the proxy retry: the upstream's
# unlock_url requires an authenticated browser session (the user must be
# signed into the provider's web console). The proxy's GET to it returns
# 200 but the server-side key state is unchanged. So the only thing we can
# usefully do is *tell the user* the URL and exit; the user clicks through
# in a browser, then re-runs harness start.
_probe_upstream_auth() {
    local api_url="${PROXY_API_URL:-}"
    local api_key="${PROXY_API_KEY:-}"
    local api_model="${PROXY_API_MODEL:-}"

    if [[ -z "$api_url" || -z "$api_key" ]]; then
        # Missing config; let other validators surface this clearly.
        return 0
    fi

    if ! command -v curl >/dev/null 2>&1; then
        # Probe needs curl. Surface it and let the user proceed without
        # the probe — other validators will catch a fundamentally broken
        # setup.
        echo "[harness] WARN: curl not available on host; skipping upstream auth probe" >&2
        return 2
    fi

    # Cheapest possible request: max_tokens=1, body just ".".
    local probe_body
    probe_body=$(printf '{"model":"%s","messages":[{"role":"user","content":"."}],"max_tokens":1}' \
        "${api_model:-default}")

    local response status_code body
    response=$(curl -sSL -k -w "\n__HTTP_STATUS__%{http_code}" \
        --connect-timeout 5 --max-time 30 \
        -X POST "$api_url" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "$probe_body" 2>&1) || true

    status_code=$(grep -o "__HTTP_STATUS__[0-9]*$" <<<"$response" | sed 's/__HTTP_STATUS__//')
    body=$(sed 's/__HTTP_STATUS__[0-9]*$//' <<<"$response" | sed '$ s/[[:space:]]*$//')

    # No status = curl failed entirely (network / DNS / connection).
    if [[ -z "$status_code" ]]; then
        echo "[harness] WARN: upstream auth probe failed (network/connection)" >&2
        echo "[harness]       starting anyway; agents may fail until upstream is reachable" >&2
        return 2
    fi

    case "$status_code" in
        2*)
            return 0
            ;;
        401|403)
            local unlock_url=""
            if command -v jq >/dev/null 2>&1; then
                unlock_url=$(jq -r '.error.unlock_url // empty' <<<"$body" 2>/dev/null || true)
            fi
            if [[ -z "$unlock_url" ]]; then
                # crude grep fallback when jq isn't on host or jq couldn't parse
                unlock_url=$(grep -oE '"unlock_url"[[:space:]]*:[[:space:]]*"[^"]*"' <<<"$body" \
                    | head -1 \
                    | sed 's/"unlock_url"[[:space:]]*:[[:space:]]*"\(.*\)"/\1/')
            fi

            echo "" >&2
            echo "================================================================" >&2
            echo " ERROR: Upstream API key is locked or invalid" >&2
            echo "================================================================" >&2
            if [[ -n "$unlock_url" ]]; then
                echo "" >&2
                echo " Visit this URL in your browser to unlock the key:" >&2
                echo "" >&2
                echo "   $unlock_url" >&2
                echo "" >&2
                echo " You must be signed in to the provider's web console for" >&2
                echo " the unlock to take effect. After unlocking, run:" >&2
                echo "   harness start" >&2
            else
                echo "" >&2
                echo " The upstream returned $status_code. Verify PROXY_API_KEY in:" >&2
                echo "   ${install_root}/.env" >&2
            fi
            echo "================================================================" >&2
            echo "" >&2
            return 1
            ;;
        429)
            echo "[harness] WARN: upstream rate-limited (429); starting anyway" >&2
            return 2
            ;;
        5*)
            echo "[harness] WARN: upstream returned $status_code; starting anyway" >&2
            return 2
            ;;
        *)
            echo "[harness] WARN: upstream returned unexpected status $status_code; starting anyway" >&2
            return 2
            ;;
    esac
}

cmd_unlock() {
    # Run the same probe `cmd_start` runs. On locked, prints the unlock URL.
    # On success, prints "key OK". Useful for mid-session lockouts: user
    # runs this, sees the URL, unlocks in the browser, and the agent's
    # next request goes through.
    if _probe_upstream_auth; then
        echo "[harness] upstream API key is OK; no unlock needed"
        return 0
    fi
    return 1
}

